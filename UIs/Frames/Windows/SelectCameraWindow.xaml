<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.SelectCameraWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    Title="Alert"
    Width="600"
    Height="400"
    PreviewKeyDown="previewKeyDown"
    ResizeMode="NoResize"
    ShowInTaskbar="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <viewModels:SelectCameraViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="NoMouseOverBorderTextBox" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Name="border"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="Transparent" />
                                <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#acacac" BorderThickness="1">
        <DockPanel>
            <StackPanel
                Height="30"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <Label Name="xTitle" Content="Alert">
                    <Label.Background>
                        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlLightLightColorKey}}" />
                    </Label.Background>
                </Label>
            </StackPanel>
            <StackPanel
                Name="xContentStackPanel"
                HorizontalAlignment="Center"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <StackPanel
                    Name="xIconStackPanel"
                    VerticalAlignment="Center"
                    Orientation="Vertical">
                    <Border Height="40" />
                    <Image
                        Name="xIcon"
                        Width="140"
                        Source="/Assets/Icons/alert.png" />
                </StackPanel>
                <StackPanel
                    Name="xImageModeStackPanel"
                    Orientation="Horizontal"
                    Visibility="Collapsed">
                    <Border Width="40" />
                    <StackPanel Orientation="Vertical">
                        <Border Height="30" />
                        <Image
                            Name="xImage"
                            Width="480"
                            Source="/Assets/Icons/add.png" />
                    </StackPanel>
                    <Border Width="30" />
                </StackPanel>
            </StackPanel>
            <StackPanel DockPanel.Dock="Top">
                <Border Height="30" />
                <ScrollViewer
                    Name="xTextBoxScrollViewer"
                    DockPanel.Dock="Top"
                    VerticalScrollBarVisibility="Auto">
                    <TextBox
                        Name="xMessage"
                        Height="70"
                        HorizontalAlignment="Center"
                        BorderBrush="Transparent"
                        FontSize="15"
                        IsReadOnly="True"
                        Style="{StaticResource NoMouseOverBorderTextBox}"
                        Text="Please select a camera."
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </StackPanel>
            <StackPanel
                Height="Auto"
                HorizontalAlignment="Center"
                DockPanel.Dock="Bottom"
                Orientation="Vertical">
                <ItemsControl ItemsSource="{Binding CameraList}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Width="80"
                                Height="30"
                                Margin="5,5,5,5"
                                Content="{Binding}"
                                Click="cameraButton_Onclick"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
