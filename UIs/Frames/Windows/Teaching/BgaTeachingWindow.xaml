                                        <Label Width="90" Content="Long Side" />
                                        <Label Content="Min Length" />
                                        <TextBox
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Teaching.MinLengthOfLongSide}"
                                            Validation.ErrorTemplate="{StaticResource validationTemplate}" />
                                        <Label Content="{Binding Symbol}" />
                                        <Border Width="20" />
                                        <Label Content="Max Length" />
                                        <TextBox
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Teaching.MaxLengthOfLongSide}"
                                            Validation.ErrorTemplate="{StaticResource validationTemplate}" />
                                        <Label Content="{Binding Symbol}" />
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox DockPanel.Dock="Bottom" Header="Teaching Test">
                                <StackPanel>
                                    <Button
                                        Click="findPackageButton_OnClick"
                                        Command="{Binding inspectSawingCommand}"
                                        Content="Inspect Sawing"
                                        Style="{StaticResource horizontalButtonStyle}" />
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Label Content="Chipping" />
                                        <TextBox
                                            IsReadOnly="True"
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Mode=TwoWay, Path=ChippingCount, StringFormat={}{0:0}, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="EA" />
                                        <Border Width="10" />
                                        <Label Content="Burr" />
                                        <TextBox
                                            IsReadOnly="True"
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Mode=TwoWay, Path=BurrCount, StringFormat={}{0:0}, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="EA" />
                                    </StackPanel>
                                    <Border Height="5" />
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Label Content="SawOffset" />
                                        <Label Content="X" />
                                        <TextBox
                                            IsReadOnly="True"
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Mode=TwoWay, Path=SawOffsetX, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="{Binding Symbol}" />
                                        <Border Width="10" />
                                        <Label Content="Y" />
                                        <TextBox
                                            IsReadOnly="True"
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Mode=TwoWay, Path=SawOffsetY, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="{Binding Symbol}" />
                                    </StackPanel>
                                    <Border Height="5" />
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Label Content="Corner Degree" />
                                        <Label Content="TL" />
                                        <TextBox
                                            IsReadOnly="True"
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Mode=TwoWay, Path=CornerDegreeTopLeft, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="TR" />
                                        <TextBox
                                            IsReadOnly="True"
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Mode=TwoWay, Path=CornerDegreeTopRight, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="BL" />
                                        <TextBox
                                            IsReadOnly="True"
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Mode=TwoWay, Path=CornerDegreeBottomLeft, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="BR" />
                                        <TextBox
                                            IsReadOnly="True"
                                            Style="{StaticResource textBoxInError}"
                                            Text="{Binding Mode=TwoWay, Path=CornerDegreeBottomRight, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="º" />
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <Border />
                        </DockPanel>
                    </TabItem>

                    <!--  Reject Mark Tab  -->
                    <TabItem Header="Reject Mark">
