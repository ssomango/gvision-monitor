                                            <Label Content="EA" />
                                            <Border Width="10" />
                                            <Label Content="Contamination" />
                                            <TextBox
                                                Style="{StaticResource textBoxInError}"
                                                Text="{Binding Mode=TwoWay, Path=ContaminationCount, StringFormat={}{0:0}, UpdateSourceTrigger=PropertyChanged}"
