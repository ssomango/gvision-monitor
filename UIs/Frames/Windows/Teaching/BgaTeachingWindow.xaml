                                        SawOffsetItems="{Binding Teaching.SawOffsetItems}"
                                        SawOffsetStandardObjects="{Binding SawOffsetStandardObjectSources}" />
                                </StackPanel>
                            </GroupBox>
                            <GroupBox DockPanel.Dock="Top" Header="Chipping/Burr">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="6" />
                                        <Label Width="90" Content="Outline Width" />
                                        <Slider
                                            Width="290"
                                            VerticalAlignment="Center"
                                            Maximum="1000"
                                            Minimum="1"
                                            Value="{Binding Teaching.OutlineWidth}" />
                                        <TextBox Style="{StaticResource textBoxInError}" Text="{Binding Teaching.OutlineWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2}}" />
                                    </StackPanel>
                                    <panels:ThresholdControllerPanel
                                        x:Name="xOutlineThresholdPanel"
                                        DrawMode="fill"
                                        Threshold="{Binding Teaching.OutlineThreshold}" />
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Label Width="90" Content="Short Side" />
                                        <Label Content="Min Length" />
