<local:FloatingWindowBase
    x:Class="GVisionWpf.UIs.Frames.Windows.FloatingMenuWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    Title="FloatingMenuWindow"
    Width="50"
    Height="109"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.DataContext>
        <viewModels:FloatingMenuViewModel />
    </Window.DataContext>

    <local:FloatingWindowBase.Resources>
        <Style TargetType="Button">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
    </local:FloatingWindowBase.Resources>

    <StackPanel>
        <Button
            Width="50"
            Height="50"
            PreviewMouseLeftButtonDown="floatingButton_OnMouseLeftButtonDown"
            PreviewMouseLeftButtonUp="floatingButton_OnMouseLeftButtonUp"
            PreviewMouseMove="floatingButton_OnMouseMove">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="50" />
                </Style>
            </Button.Resources>
            <StackPanel>
                <Image Margin="10" Source="/Assets/Icons/menu-dots-vertical.png" />
            </StackPanel>
        </Button>
        <StackPanel x:Name="xFloatingMenuStackPanel" Margin="0,5,0,5">
            <Button 
                Width="50"
                Height="50"
                Command="{Binding OpenChatWindowCommand}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="50" />
                    </Style>
                </Button.Resources>
                <StackPanel>
                    <Image Margin="10" Source="/Assets/Icons/chat/bubble-chat.png"/>
                </StackPanel>
            </Button>
            <Border Height="5" />
        </StackPanel>
    </StackPanel>
</local:FloatingWindowBase>
