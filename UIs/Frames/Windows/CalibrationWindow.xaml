<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.CalibrationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:calibrationTabs="clr-namespace:GVisionWpf.UIs.Frames.Tabs.Calibrations"
    xmlns:calibrations="clr-namespace:GVisionWpf.UIs.ViewModels.Calibrations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:types="clr-namespace:GVisionWpf.Types"
    xmlns:utils="clr-namespace:GVisionWpf.Utils"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    Title="Calibration Wizard"
    Width="1050"
    Height="900"
    d:DataContext="{d:DesignInstance Type=calibrations:CalibrationViewModel}"
    Loaded="window_Loaded"
    ResizeMode="NoResize"
    ShowInTaskbar="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>
        <!--  DataTemplates for Calibration Tabs  -->
        <DataTemplate DataType="{x:Type calibrations:BottomJigCalibrationTabViewModel}">
            <calibrationTabs:BasicCalibrationTab />
        </DataTemplate>
        <DataTemplate DataType="{x:Type calibrations:SettingJigCalibrationTabViewModel}">
            <calibrationTabs:BasicCalibrationTab />
        </DataTemplate>
        <DataTemplate DataType="{x:Type calibrations:PadPitchCalibrationTabViewModel}">
            <calibrationTabs:BasicCalibrationTab />
        </DataTemplate>
        <DataTemplate DataType="{x:Type calibrations:TrayCalibrationTabViewModel}">
            <calibrationTabs:BasicCalibrationTab />
        </DataTemplate>
        <DataTemplate DataType="{x:Type calibrations:VisionTableCalibrationTabViewModel}">
            <calibrationTabs:BasicCalibrationTab />
        </DataTemplate>
        

        <!--  DataTemplate for Light Controller  -->
        <DataTemplate x:Key="LightControllerItemTemplate">
            <panels:LightControllerPanel x:Name="xLightControllerPanel" DataContext="{Binding}" />
        </DataTemplate>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5,0" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <utils:CalibrationSelectConverter x:Key="SelectConverter" />
    </Window.Resources>

    <Border
        Background="#f0f0f0"
        BorderBrush="#acacac"
        BorderThickness="1">

        <Grid x:Name="xPickerOffsetWindowGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="450" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
                <RowDefinition Height="300" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <!--  Title Label  -->
            <Label
                Grid.Row="0"
                Grid.ColumnSpan="2"
                HorizontalContentAlignment="Left"
                Content=" Calibration Wizard"
                PreviewMouseDown="xTitleBarLabel_PreviewMouseDown"
                PreviewMouseMove="xTitleBarLabel_PreviewMouseMove">
                <Label.Background>
                    <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlLightLightColorKey}}" />
                </Label.Background>
            </Label>

            <!--  Vision Window  -->
            <Border
                Grid.Row="1"
                Grid.Column="0"
                Margin="5"
                BorderBrush="#acacac"
                BorderThickness="1">
                <panels:VisionWindow x:Name="xVisionWindow" />
            </Border>

            <DockPanel
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,5,5,5">

                <!--  Calibration Settings  -->
                <Border
                    Margin="0,5,0,0"
                    Background="White"
                    BorderBrush="#acacac"
                    BorderThickness="1"
                    DockPanel.Dock="Bottom">
                    <StackPanel Margin="2,5">
                        <GroupBox Header="Reticle Type">
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <RadioButton
                                    Command="{Binding ReticleTypeCommand}"
                                    CommandParameter="{x:Static types:EReticleType.None}"
                                    Content="None"
                                    GroupName="ReticleTypeSelect"
                                    IsChecked="{Binding ReticleType, Converter={StaticResource SelectConverter}, ConverterParameter={x:Static types:EReticleType.None}}" />
                                <Border Width="10" />
                                <RadioButton
                                    Command="{Binding ReticleTypeCommand}"
                                    CommandParameter="{x:Static types:EReticleType.Default}"
                                    Content="Default"
                                    GroupName="ReticleTypeSelect"
                                    IsChecked="{Binding ReticleType, Converter={StaticResource SelectConverter}, ConverterParameter={x:Static types:EReticleType.Default}}" />
                                <Border Width="10" />
                                <RadioButton
                                    Command="{Binding ReticleTypeCommand}"
                                    CommandParameter="{x:Static types:EReticleType.FullSize}"
                                    Content="Full Size"
                                    GroupName="ReticleTypeSelect"
                                    IsChecked="{Binding ReticleType, Converter={StaticResource SelectConverter}, ConverterParameter={x:Static types:EReticleType.FullSize}}" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </Border>

                <!--  Calibration Teaching Tabs  -->
                <TabControl
                    ItemsSource="{Binding TabViewModels}"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    SelectedItem="{Binding SelectedTabViewModel}" SelectionChanged="TabControl_SelectionChanged">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TabName}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>
            </DockPanel>

            <!--  Calibration Logs  -->
            <Border
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,0,5,0"
                BorderBrush="#acacac"
                BorderThickness="1">
                <DockPanel>
                    <Label
                        Background="#c8102e"
                        Content="Calibration Logs"
                        DockPanel.Dock="Top"
                        FontSize="15"
                        FontWeight="Bold"
                        Foreground="White" />
                    <ListView
                        x:Name="listView"
                        d:ItemsSource="{d:SampleData ItemCount=5}"
                        BorderThickness="0"
                        ItemsSource="{Binding Results}"
                        SelectedItem="{Binding SelectedResult}">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="MouseDoubleClick">
                                <b:InvokeCommandAction Command="{Binding ItemDoubleClickCommand}" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ListView>
                </DockPanel>
            </Border>

            <!--  Light Control  -->
            <Border
                Grid.Row="2"
                Grid.Column="0"
                Margin="5,0"
                BorderBrush="#acacac"
                BorderThickness="1">
                <DockPanel Background="White">
                    <Label
                        Background="#c8102e"
                        Content="Light Control"
                        DockPanel.Dock="Top"
                        FontSize="15"
                        FontWeight="Bold"
                        Foreground="White" />
                    <StackPanel
                        Margin="0,5"
                        HorizontalAlignment="Center"
                        DockPanel.Dock="Top"
                        Orientation="Horizontal">
                        <Label Content="Camera" />
                        <ComboBox
                            Width="150"
                            Height="30"
                            ItemsSource="{Binding CameraItemsSource}"
                            SelectedValue="{Binding CameraSelectedValue}"
                            SelectionChanged="comboBox_SelectionChanged" />
                    </StackPanel>
                    <ScrollViewer VerticalAlignment="Stretch">
                        <StackPanel
                            Width="550"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <ItemsControl
                                x:Name="xItemsControl"
                                ItemTemplate="{StaticResource LightControllerItemTemplate}"
                                ItemsSource="{Binding LightControllerCollection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <StackPanel
                Grid.Row="3"
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <!--  Test Button  -->
                <Button
                    Width="100"
                    Height="40"
                    Margin="0,5,5,5"
                    HorizontalAlignment="Right"
                    Command="{Binding TestCommand}"
                    Content="Test" />

                <!--  Light Save Button  -->
                <Button
                    Width="100"
                    Height="40"
                    Margin="0,5,5,5"
                    HorizontalAlignment="Right"
                    Command="{Binding LightSaveCommand}"
                    Content="Light Save" />

                <!--  Exit Button  -->
                <Button
                    Width="100"
                    Height="40"
                    Margin="0,5,5,5"
                    Click="closeButton_Click"
                    Command="{Binding CloseWindowCommand}"
                    Content="Exit" />
            </StackPanel>
        </Grid>
    </Border>
</Window>