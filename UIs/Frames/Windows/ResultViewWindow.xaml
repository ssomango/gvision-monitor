<local:FloatingWindowBase
    x:Class="GVisionWpf.UIs.Frames.Windows.ResultViewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    Width="200"
    MinWidth="200"
    MinHeight="57"
    MaxWidth="200"
    d:DataContext="{d:DesignInstance Type=viewModels:MapResultViewViewModel}"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            GlassFrameThickness="5"
            ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="StackPanelTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border
        BorderBrush="#acacac"
        BorderThickness="0"
        CornerRadius="10 10 0 0">
        <Grid x:Name="xResultViewWindow">
            <Grid.RowDefinitions>
                <RowDefinition Height="22" />
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  타이틀바  -->
            <Grid x:Name="xTitleBar" Grid.Row="0">
                <panels:FloatingWindowTitleBarPanel
                    Title="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                    CanMaximized="{Binding CanMaximized, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                    IsFixed="{Binding IsFixed, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=TwoWay}"
                    IsMaximized="{Binding IsMaximized, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=TwoWay}" />
            </Grid>

            <Border
                Grid.Row="1"
                BorderBrush="#acacac"
                BorderThickness="1,1,1,0">
                <!--  메인 컨텐츠  -->
                <Grid Background="WhiteSmoke">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Avg Duration" />
                    <TextBox
                        x:Name="xTopAverageDurationTextBox"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="5"
                        FontSize="16"
                        Text="{Binding AverageDuration, StringFormat={}{0:F2}}" />
                    <Label
                        Grid.Column="2"
                        VerticalContentAlignment="Center"
                        Content="ms" />
                </Grid>
            </Border>

            <Border
                Grid.Row="2"
                BorderBrush="#acacac"
                BorderThickness="1,0,1,1">
                <ScrollViewer Background="WhiteSmoke"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding InspectionViewModels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Left"
                                            Margin="4, 0, 12, 0">
                                    <Rectangle
                                            Width="14" Height="14"
                                            Margin="4"
                                            Fill="{Binding Color, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Stroke="Black"
                                            StrokeThickness="0.5" />

                                    <TextBox
                                            Width="100"
                                            Style="{StaticResource StackPanelTextBox}"
                                            Text="{Binding ErrorType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBox
                                            Width="30"
                                            VerticalContentAlignment="Center"
                                            FontWeight="Bold"
                                            Style="{StaticResource StackPanelTextBox}"
                                            Text=":" />

                                    <TextBox
                                            x:Name="xInspectionResultCountTextBox"
                                            Margin="0,0,10,0"
                                            BorderThickness="0"
                                            Style="{StaticResource StackPanelTextBox}"
                                            Text="{Binding Count, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TextAlignment="Right" />

                                    <TextBlock
                                            x:Name="xStandardValueTextBox"
                                            Visibility="{Binding StandardValueVisibility}"
                                            Text="{Binding StandardValue}">
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</local:FloatingWindowBase>
