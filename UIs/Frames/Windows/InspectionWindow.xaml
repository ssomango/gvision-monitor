<local:FloatingWindowBase
    x:Class="GVisionWpf.UIs.Frames.Windows.InspectionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ha="http://schemas.mvtec.com/halcondotnet"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:utils="clr-namespace:GVisionWpf.Utils"
    xmlns:types="clr-namespace:GVisionWpf.Types"
    MinWidth="292"
    MinHeight="300"
    d:DesignHeight="400"
    d:DesignWidth="400"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            ResizeBorderThickness="5"
            GlassFrameThickness="5">
        </WindowChrome>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <utils:VisionWindowToolsToolTipConverter
            x:Key="ToolBoxTooTipConverter">
        </utils:VisionWindowToolsToolTipConverter>
    </Window.Resources>

    <Border
        BorderBrush="#acacac"
        BorderThickness="0"
        CornerRadius="10 10 0 0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="22" />
                <RowDefinition
                    Height="*" />
                <RowDefinition
                    Height="30" />
            </Grid.RowDefinitions>

            <!--  타이틀바  -->
            <Grid
                x:Name="xTitleBar"
                Grid.Row="0">
                <panels:FloatingWindowTitleBarPanel
                    Title="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                    CanMaximized="{Binding CanMaximized, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                    IsFixed="{Binding IsFixed, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=TwoWay}"
                    IsMaximized="{Binding IsMaximized, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=TwoWay}" />
            </Grid>

            <!--  메인 컨텐츠  -->
            <Border
                Grid.Row="1"
                Grid.Column="0"
                BorderBrush="#acacac"
                BorderThickness="1">
                <panels:VisionWindow
                    x:Name="xVisionWindow" />
            </Border>

            <Border
                Grid.Row="2"
                Grid.Column="0"
                BorderBrush="#acacac"
                BorderThickness="1,0,1,1">
            <DockPanel
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center">
                <Button
                    Click="grayValueButton_Click"
                    DockPanel.Dock="Right"
                    BorderThickness="0,0,0,0"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:EVisionWindowTools.GrayValue}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image
                        Margin="2"
                        Source="/Assets/Icons/grayValue.png" />
                </Button>
                <Button
                    Click="textDisplayButton_Click"
                    DockPanel.Dock="Right"
                    BorderThickness="0,0,1,0"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:EVisionWindowTools.Text}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image
                        Margin="2"
                        Source="/Assets/Icons/text.png" />
                </Button>
                <Button
                    Click="overlayButton_Click"
                    DockPanel.Dock="Right"
                    BorderThickness="0,0,1,0"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:EVisionWindowTools.Overlay}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image
                        Margin="2"
                        Source="/Assets/Icons/overlay.png" />
                </Button>
                <Button
                    Click="deviceViewVisibleButton_Click"
                    DockPanel.Dock="Right"
                    BorderThickness="0,0,1,0"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:EVisionWindowTools.DeviceView}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image
                        Margin="2"
                        Source="/Assets/Icons/Grid.png" />
                </Button>
                <Button
                    Click="zoomInButton_Click"
                    DockPanel.Dock="Right"
                    BorderThickness="0,0,1,0"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:EVisionWindowTools.ZoomIn}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image
                        Margin="2"
                        Source="/Assets/Icons/zoom-in.png" />
                </Button>
                <Button
                    Click="zoomOutButton_Click"
                    DockPanel.Dock="Right"
                    BorderThickness="0,0,1,0"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:EVisionWindowTools.ZoomOut}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image
                        Margin="2"
                        Source="/Assets/Icons/zoom-out.png" />
                </Button>
                <Button
                    Click="zoomResetButton_Click"
                    DockPanel.Dock="Right"
                    BorderThickness="0,0,1,0"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:EVisionWindowTools.ZoomReset}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image
                        Margin="2"
                        Source="/Assets/Icons/reset-zoom.png" />
                </Button>
                <Button
                    IsEnabled="False"
                    BorderThickness="0,0,1,0"
                    Background="#eaeaea"
                    Style="{StaticResource ImageButtonStyle}" />
            </DockPanel>
            </Border>
        </Grid>
    </Border>
</local:FloatingWindowBase>