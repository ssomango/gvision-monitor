<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.LotWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    Title="LotWindow"
    Width="900"
    Height="700"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.DataContext>
        <viewModels:LotViewModel />
    </Window.DataContext>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="BorderBrush" Value="#acacac" />
            <Setter Property="Height" Value="26" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD2ECFD" />
                    <Setter Property="Foreground" Value="Black" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type DataGridRowHeader}">
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="DataGridTextColumnTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#acacac" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Padding" Value="3,0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFD2ECFD" />
                    <Setter Property="Foreground" Value="Black" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="35" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="#acacac" BorderThickness="1">
        <DockPanel>
            <StackPanel
                Height="30"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <Label Content="Lot Data">
                    <Label.Background>
                        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlLightLightColorKey}}" />
                    </Label.Background>
                </Label>
            </StackPanel>

            <StackPanel
                Height="40"
                Margin="5,5,4,4"
                HorizontalAlignment="Right"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Click="exitBtn_Click"
                    Content="Exit" />
            </StackPanel>

            <StackPanel
                Margin="30,10,30,20"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                    <Label
                        Margin="3"
                        Padding="2"
                        Background="#c8102e"
                        Content="Database"
                        FontSize="15"
                        FontWeight="Bold"
                        Foreground="White" />
                    <ComboBox
                        Width="180"
                        ItemsSource="{Binding DatabaseNames}"
                        SelectedItem="{Binding SelectedDatabaseName}" />
                </StackPanel>
                <Border Width="520" />
                <StackPanel Margin="3" Orientation="Horizontal">
                    <Button
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding SaveCommand}">
                        <StackPanel Width="50">
                            <Image Margin="4" Source="/Assets/Icons/save.png" />
                            <Label
                                Padding="0,0,0,2"
                                Content="Save"
                                FontSize="9" />
                        </StackPanel>
                    </Button>
                    <Border Width="10" />
                    <Button 
                        Background="Transparent" 
                        BorderBrush="Transparent"
                        Command="{Binding deleteSelectedItemsCommand}">
                        <StackPanel Width="50">
                            <Image Margin="6" Source="/Assets/Icons/trash.png" />
                            <Label
                                Padding="0,0,0,2"
                                Content="Clear"
                                FontSize="9" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <DataGrid
                x:Name="xLotDataGrid"
                Margin="5,0,5,1"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                DockPanel.Dock="Top"
                EnableColumnVirtualization="True"
                EnableRowVirtualization="True"
                GridLinesVisibility="None"
                ItemsSource="{Binding LotDataGridItemsSource}"
                MouseDoubleClick="dataGrid_OnMouseDoubleClick"
                ScrollViewer.ScrollChanged="dataGrid_ScrollChanged"
                SelectedIndex="{Binding LotDataGridSelectedIndex}"
                SelectionMode="Extended"
                VirtualizingStackPanel.IsVirtualizing="True"
                VirtualizingStackPanel.VirtualizationMode="Recycling">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding Id}"
                        ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                        Header="NO"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="4*"
                        Binding="{Binding Package}"
                        ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                        Header="PACKAGE"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="4*"
                        Binding="{Binding LotNumber}"
                        ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                        Header="LOT NUMBER"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="6*"
                        Binding="{Binding StartTime}"
                        ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                        Header="START TIME"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="6*"
                        Binding="{Binding EndTime}"
                        ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                        Header="END TIME"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="4*"
                        Binding="{Binding Ellapsed}"
                        ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                        Header="ELLAPSED"
                        IsReadOnly="True" />
                </DataGrid.Columns>
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding SelectionChangeCommand}" CommandParameter="{Binding ElementName=xLotDataGrid, Path=SelectedItems}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </DataGrid>
        </DockPanel>
    </Border>
</Window>
