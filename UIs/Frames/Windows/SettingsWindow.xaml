<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:types="clr-namespace:GVisionWpf.Types"
    xmlns:utils="clr-namespace:GVisionWpf.Utils"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    xmlns:vm="clr-namespace:GVisionWpf.UIs.ViewModels.TreeView"
    Title="SettingsWindow"
    Width="1000"
    Height="700"
    d:DataContext="{d:DesignInstance Type=viewModels:SettingsViewModel}"
    d:DesignHeight="2000"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <viewModels:SettingsViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
            <Setter Property="Margin" Value="10,0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>

        <ObjectDataProvider
            x:Key="xSaveOptionProvider"
            MethodName="GetValues"
            ObjectType="{x:Type system:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="types:ESaveOption" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <utils:EnumToUpperConverter x:Key="EnumToUpperConverter" />
        <utils:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </Window.Resources>

    <Border BorderBrush="#acacac" BorderThickness="1">
        <DockPanel>
            <StackPanel
                Height="30"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <Label Content="Settings Wizard">
                    <Label.Background>
                        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlLightLightColorKey}}" />
                    </Label.Background>
                </Label>
            </StackPanel>

            <StackPanel
                Height="40"
                Margin="5,5,4,4"
                HorizontalAlignment="Right"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Command="{Binding SaveCommand}"
                    Content="Save" />
                <Border Width="10" />
                <Button
                    Width="100"
                    Click="exitBtn_Onclick"
                    Content="Exit" />
            </StackPanel>

            <TabControl Margin="-1,5,-1,-1">

                <TabItem Header="Recipe">
                    <StackPanel>
                        <Border Height="30" />

                        <StackPanel HorizontalAlignment="Center">
                            <GroupBox Header="Select Recipe">
                                <StackPanel>
                                    <Border Height="5" />
                                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                        <Border Width="3" />
                                        <Label Content="Current Recipe:" />
                                        <Border Width="10" />
                                        <Label Content="{Binding SelectedRecipeName}" FontWeight="Bold" />
                                    </StackPanel>
                                    <StackPanel
                                        Height="300"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                        <TreeView
                                            Width="300"
                                            Margin="10"
                                            BorderBrush="#acacac"
                                            DataContext="{Binding TreeViewModel}"
                                            ItemsSource="{Binding Tree.Root.Children}"
                                            SelectedItemChanged="TreeView_OnSelectedItemChanged">
                                            <TreeView.Resources>
                                                <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}" ItemsSource="{Binding Children}">
                                                    <TextBlock Text="{Binding Data.Name}" />
                                                </HierarchicalDataTemplate>
                                            </TreeView.Resources>
                                        </TreeView>

                                        <StackPanel Margin="0,0,5,0">
                                            <Button
                                                VerticalAlignment="Top"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Command="{Binding AddRecipeCommand}">
                                                <StackPanel Width="50">
                                                    <Image Margin="6" Source="/Assets/Icons/add.png" />
                                                    <Label
                                                        Padding="0,0,0,2"
                                                        HorizontalContentAlignment="Center"
                                                        Content="Add"
                                                        FontSize="9" />
                                                </StackPanel>
                                            </Button>
                                            <Border Height="10" />
                                            <Button
                                                VerticalAlignment="Top"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Command="{Binding RenameRecipeCommand}">
                                                <StackPanel Width="50">
                                                    <Image Margin="6" Source="/Assets/Icons/rename.png" />
                                                    <Label
                                                        Padding="0,0,0,2"
                                                        HorizontalContentAlignment="Center"
                                                        Content="Rename"
                                                        FontSize="9" />
                                                </StackPanel>
                                            </Button>
                                            <Border Height="94" />
                                            <Button
                                                Height="50"
                                                Command="{Binding SelectRecipeCommand}"
                                                Content="Select" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,5,0">
                                            <Button
                                                VerticalAlignment="Top"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Command="{Binding CopyRecipeCommand}">
                                                <StackPanel Width="50">
                                                    <Image Margin="6" Source="/Assets/Icons/copy.png" />
                                                    <Label
                                                        Padding="0,0,0,2"
                                                        HorizontalContentAlignment="Center"
                                                        Content="Copy"
                                                        FontSize="9" />
                                                </StackPanel>
                                            </Button>
                                            <Border Height="10" />
                                            <Button
                                                VerticalAlignment="Top"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Command="{Binding DeleteRecipeCommand}">
                                                <StackPanel Width="50">
                                                    <Image Margin="6" Source="/Assets/Icons/trash.png" />
                                                    <Label
                                                        Padding="0,0,0,2"
                                                        HorizontalContentAlignment="Center"
                                                        Content="Delete"
                                                        FontSize="9" />
                                                </StackPanel>
                                            </Button>
                                            <Border Height="10" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>

                        <Border Height="20" />

                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                            <GroupBox Header="Teaching Info">
                                <StackPanel Margin="5">
                                    <StackPanel Orientation="Vertical">
                                        <Border Height="1" />
                                        <Button
                                            Width="100"
                                            Height="30"
                                            Background="{Binding HasMappingRecipeBackground}"
                                            Content="Mapping" />
                                        <Border Height="10" />
                                        <Button
                                            Width="100"
                                            Height="30"
                                            Background="{Binding HasPrsRecipeBackground}"
                                            Content="PRS" />
                                        <Border Height="10" />
                                        <Button
                                            Width="100"
                                            Height="30"
                                            Background="{Binding HasBarCodeRecipeBackground}"
                                            Content="Bar Code" />
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Table Info">
                                <StackPanel Margin="5,0,5,0">
                                    <Border Height="5" />
                                    <StackPanel
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Label HorizontalContentAlignment="Center" Content="Table Size" />
                                        <Border Width="100" />
                                        <Label HorizontalContentAlignment="Center" Content="FOV Size" />
                                        <Border Width="100" />
                                        <Label HorizontalContentAlignment="Center" Content="Block Size" />
                                    </StackPanel>
                                    <Border Height="5" />
                                    <StackPanel Height="30" Orientation="Horizontal">
                                        <Label
                                            Width="80"
                                            HorizontalContentAlignment="Right"
                                            Content="Row (Y) " />
                                        <TextBox Text="{Binding TrayRowCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="EA" />
                                        <Label
                                            Width="80"
                                            HorizontalContentAlignment="Right"
                                            Content="Row (Y)" />
                                        <TextBox Text="{Binding FovRowCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="EA" />
                                        <Label
                                            Width="80"
                                            HorizontalContentAlignment="Right"
                                            Content="Row (Y)" />
                                        <TextBox Text="{Binding BlockRowCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="EA" />
                                    </StackPanel>
                                    <Border Height="10" />
                                    <StackPanel Height="30" Orientation="Horizontal">
                                        <Label
                                            Width="80"
                                            HorizontalContentAlignment="Right"
                                            Content="Column (X)" />
                                        <TextBox Text="{Binding TrayColCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="EA" />
                                        <Label
                                            Width="80"
                                            HorizontalContentAlignment="Right"
                                            Content="Column (X)" />
                                        <TextBox Text="{Binding FovColCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="EA" />
                                        <Label
                                            Width="80"
                                            HorizontalContentAlignment="Right"
                                            Content="Column (X)" />
                                        <TextBox Text="{Binding BlockColCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Label Content="EA" />
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Device Info">
                                <StackPanel Margin="5,0,5,0">
                                    <Border Height="5" />
                                    <StackPanel Height="30" Orientation="Horizontal">
                                        <Label
                                            Width="50"
                                            HorizontalContentAlignment="Right"
                                            Content="MAP" />
                                        <ComboBox
                                            Width="70"
                                            ItemsSource="{Binding PackageTypes}"
                                            SelectedItem="{Binding MapPackageType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <Border Height="5"/>
                                    
                                    <StackPanel Height="30" Orientation="Horizontal">
                                        <Label
                                            Width="50"
                                            HorizontalContentAlignment="Right"
                                            Content="PRS" />
                                        <ComboBox  
                                            Width="70"
                                            ItemsSource="{Binding PackageTypes}"
                                            SelectedItem="{Binding PrsPackageType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <Border Height="5" />
                                    <StackPanel Height="30" Orientation="Horizontal">
                                        <Label
                                            Width="70"
                                            HorizontalContentAlignment="Right"
                                            Content="Width (X)" />
                                        <TextBox Text="{Binding PackageWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        <Label Content="{Binding Symbol}" />
                                    </StackPanel>
                                    <Border Height="10" />
                                    <StackPanel Height="30" Orientation="Horizontal">
                                        <Label
                                            Width="70"
                                            HorizontalContentAlignment="Right"
                                            Content="Height (Y)" />
                                        <TextBox Text="{Binding PackageHeight, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        <Label Content="{Binding Symbol}" />
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Vision Use/Skip">
                                <StackPanel Margin="5">
                                    <StackPanel Orientation="Vertical">
                                        <Border Height="1" />
                                        <Button
                                            Width="100"
                                            Height="30"
                                            Background="{Binding UseMappingBackground}"
                                            Command="{Binding UseMappingCommand}"
                                            Content="Mapping" />
                                        <Border Height="10" />
                                        <Button
                                            Width="100"
                                            Height="30"
                                            Background="{Binding UsePrsBackground}"
                                            Command="{Binding UsePrsCommand}"
                                            Content="PRS" />
                                        <Border Height="10" />
                                        <Button
                                            Width="100"
                                            Height="30"
                                            Background="{Binding UseBarCodeBackground}"
                                            Command="{Binding UseBarCodeCommand}"
                                            Content="Bar Code" />
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <!--  Mapping Inspection Items Tab  -->
                <TabItem Header="MOLD Inspection"
                         Visibility="{Binding MoldInspectionVisbility}">
                    <!--  Mapping Package Inspection GroupBox  -->
                    <ScrollViewer>
                        <StackPanel>
                            <GroupBox Header="Package Inspection">
                                
                                <StackPanel Margin="5" Orientation="Vertical">

                                    <StackPanel x:Name="MoldNoDevicePanel"
                                                Orientation ="Horizontal"
                                                Margin="0,0,0,10">

                                        <CheckBox IsChecked="True" IsEnabled="False" />
                                        <Label Width="150" Content="No Device" />
                                        <StackPanel Width="300" Orientation="Horizontal" />
                                        <ComboBox
                                                Width="100"
                                                ItemsSource="{Binding ResultColors}"
                                                SelectedItem="{Binding MapNoDeviceColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                                Width="16" Height="16"  Margin="2"
                                                                Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                                Margin="5,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel x:Name="MoldXOutPanel"
                                        Orientation="Horizontal" 
                                                Margin="0,0,0,10">
                                        
                                        <CheckBox IsChecked="True" IsEnabled="False" />
                                        <Label Width="150" Content="XOut" />
                                        <StackPanel Width="300" Orientation="Horizontal" />
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MapXOutColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel x:Name="MoldXOut2Panel"
                                        Orientation="Horizontal"
                                                Margin="0,0,0,10">
                                        
                                        <CheckBox IsChecked="True" IsEnabled="False" />
                                        <Label Width="150" Content="XOut2" />
                                        <StackPanel Width="300" Orientation="Horizontal" />
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MapXOut2Color}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                   
                                    <StackPanel x:Name="MoldPackageSizePanel"
                                        Orientation="Horizontal"
                                                Margin="0,0,0,10">
                                                
                                        <CheckBox IsChecked="{Binding UseMapPackageSize}" />
                                        <Label Width="150" Content="Package Size" />
                                        <StackPanel Width="300" Orientation=" Horizontal">
                                            <Label Content="± Width" />
                                            <TextBox Text="{Binding MapPackageSizeWidth}" />
                                            <Label Content="Height" />
                                            <TextBox Text="{Binding MapPackageSizeHeight}" />
                                            <Label Content="{Binding Symbol}" />
                                            <Border Width="20" />
                                        </StackPanel>
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MapPackageSizeColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    
                                    <StackPanel x:Name="MoldPackageOffsetPanel"
                                        Orientation="Horizontal"
                                                Margin="0,0,0,10">
                                        <CheckBox IsChecked="{Binding UseMapPackageOffset}" />
                                        <Label Width="150" Content="Package Offset" />
                                        <StackPanel Width="300" Orientation="Horizontal" />
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MapPackageOffsetColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                
                                    <StackPanel x:Name="MoldRejectMarkPanel"
                                        Orientation="Horizontal">
                                        
                                        <CheckBox IsChecked="{Binding UseMapRejectMark}" />
                                        <Label Width="150" Content="Reject Mark" />
                                        <StackPanel Width="300" Orientation="Horizontal" />
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MapRejectMarkColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    
                                </StackPanel>
                            </GroupBox>
                            <!--  Map Outline Inspection Check GroupBox  -->
                            <GroupBox Header="Outline Inspection">
                                <StackPanel Margin="5">
                                    
                                    <StackPanel x:Name="MoldCornerDegreePanel"
                                        Orientation="Horizontal"
                                                Margin="0,0,0,10">
                                        <CheckBox IsChecked="{Binding UseMapCornerDegree}" />
                                        <Label Width="150" Content="Corner Degree" />
                                        <StackPanel Width="300" Orientation="Horizontal">
                                            <Label Content="±" />
                                            <TextBox Text="{Binding MapCornerDegree}" />
                                            <Label Content="°" />
                                            <Border Width="20" />
                                        </StackPanel>
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MapCornerDegreeColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                
                                    <StackPanel x:Name="MoldSawOffsetPanel"
                                        Orientation="Horizontal"
                                                Margin="0,0,0,10">
                                        <CheckBox IsChecked="{Binding UseMapSawOffset}" />
                                        <Label Width="150" Content="Saw Offset" />
                                        <StackPanel Width="300" Orientation="Horizontal">
                                            <Label Content="±" />
                                            <Label Content="X" />
                                            <TextBox Text="{Binding MappingSawOffsetX}" />
                                            <Label Content="Y" />
                                            <TextBox Text="{Binding MappingSawOffsetY}" />
                                            <Label Content="{Binding Symbol}" />
                                            <Border Width="20" />
                                        </StackPanel>
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MappingSawOffsetColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    
                                    <StackPanel x:Name="MoldChippingPanel"
                                        Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding UseMapChipping}" />
                                        <Label Width="150" Content="Chipping" />
                                        <StackPanel Width="300" Orientation="Horizontal">
                                            <Border Width="20" />
                                        </StackPanel>
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MapChippingColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <!--  Mapping Text Inspection GroupBox  -->
                            <GroupBox Header="FixedText Inspection">
                                <StackPanel Margin="5">

                                    <StackPanel x:Name="MoldNoMarkPanel"
                                        Orientation="Horizontal"
                                                Margin="0,0,0,10">
                                        <CheckBox IsChecked="{Binding UseMapNoMark}" />
                                        <Label Width="150" Content="No Mark" />
                                        <StackPanel Width="300" Orientation=" Horizontal">
                                            <Label Content="=" />
                                            <TextBox Text="{Binding MarkCount}" />
                                            <Border Width="20" />
                                        </StackPanel>
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MapNoMarkColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel x:Name="MoldMarkCountPanel"
                                        Orientation="Horizontal"
                                                Margin="0,0,0,10">
                                        <CheckBox IsChecked="{Binding UseMapMarkCount}" />
                                        <Label Width="150" Content="Mark Count" />
                                        <StackPanel Width="300" Orientation="Horizontal" />
                                        <ComboBox
                                  Width="100"
                                  ItemsSource="{Binding ResultColors}"
                                  SelectedItem="{Binding MapMarkCountColor}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle
                                                  Width="16"
                                                  Height="16"
                                                  Margin="2"
                                                  Fill="{Binding Converter={StaticResource ColorToBrushConverter}}" />
                                                        <TextBlock
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
