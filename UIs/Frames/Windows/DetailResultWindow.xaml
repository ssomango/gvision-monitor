<local:FloatingWindowBase
    x:Class="GVisionWpf.UIs.Frames.Windows.DetailResultWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ha="http://schemas.mvtec.com/halcondotnet"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    d:DesignHeight="700"
    d:DesignWidth="400"
    AllowsTransparency="True"
    Background="Transparent"
    Visibility="{Binding Visibility, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            GlassFrameThickness="5"
            ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="22" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!--  타이틀바  -->
        <Border x:Name="xTitleBar">
            <panels:FloatingWindowTitleBarPanel
                Title="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                CanMaximized="{Binding CanMaximized, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                IsFixed="{Binding IsFixed, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=TwoWay}"
                IsMaximized="{Binding IsMaximized, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=TwoWay}" />
        </Border>

        <!--  메인 컨텐츠  -->
        <Border
            Grid.Row="1"
            BorderBrush="#acacac"
            BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Visible">
                <RichTextBox
                    x:Name="xRichTextBox"
                    BorderThickness="0"
                    FontSize="14"
                    IsReadOnly="True" />
            </ScrollViewer>
        </Border>

        <!--  닫기 버튼  -->
        <Border
            Grid.Row="2"
            Background="#f0f0f0"
            BorderBrush="#acacac"
            BorderThickness="1,0,1,1">
            <Button
                Width="80"
                Margin="5"
                HorizontalAlignment="Right"
                BorderBrush="#acacac"
                Click="closeButton_Click"
                Content="CLOSE">
                <Button.Background>
                    <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
                </Button.Background>
            </Button>
        </Border>
    </Grid>
</local:FloatingWindowBase>