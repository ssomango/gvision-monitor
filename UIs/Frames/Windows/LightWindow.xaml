<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.LightWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:utils="clr-namespace:GVisionWpf.Utils"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    Title="LightWindow"
    Width="1130"
    Height="1000"
    d:DataContext="{d:DesignInstance Type=viewModels:LightViewModel}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate x:Key="LightControllerItemTemplate">
            <panels:LightControllerPanel x:Name="xLightControllerPanel" DataContext="{Binding}" />
        </DataTemplate>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="BorderBrush" Value="#acacac" />
            <Setter Property="Height" Value="26" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD2ECFD" />
                    <Setter Property="Foreground" Value="Black" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGridRowHeader}">
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="35" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="#acacac" BorderThickness="1">
        <DockPanel>
            <StackPanel
                Height="30"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <Label Content="Light Controller">
                    <Label.Background>
                        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlLightLightColorKey}}" />
                    </Label.Background>
                </Label>
            </StackPanel>

            <StackPanel
                Height="40"
                Margin="5,5,4,4"
                HorizontalAlignment="Right"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Command="{Binding SaveCommand}"
                    Content="Save" />
                <Border Width="10" />
                <Button
                    Width="100"
                    Click="exitBtn_Click"
                    Content="Exit" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                <Border Width="10" />
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <panels:CameraPanel
                            x:Name="xLivePanel"
                            Width="600"
                            Height="600" />
                        <Border Width="10" />
                        <StackPanel Width="495">
                            <Label
                                Background="#c8102e"
                                Content="Light Control"
                                FontSize="15"
                                FontWeight="Bold"
                                Foreground="White" />
                            <Border Height="5" />
                            <ScrollViewer Height="560">
                                <StackPanel
                                    Width="460"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                    <ItemsControl
                                        x:Name="xItemsControl"
                                        ItemTemplate="{StaticResource LightControllerItemTemplate}"
                                        ItemsSource="{Binding LightControllerCollection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </StackPanel>
                    <Border Height="10" />
                    <StackPanel>
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <Label Content="Camera" />
                            <ComboBox
                                Width="150"
                                Height="30"
                                ItemsSource="{Binding CameraItemsSource}"
                                SelectedValue="{Binding CameraSelectedValue}"
                                SelectionChanged="comboBox_SelectionChanged" />
                            <Button
                                Width="100"
                                Command="{Binding PrsTestCommand}"
                                Content="PRS TEST" />
                            <Border Width="630" />
                            <Label Content="Multi-shots" />
                            <Button
                                Width="50"
                                Command="{Binding AddCommand}"
                                Content="Add" />
                            <Border Width="5" />
                            <Button
                                Width="50"
                                Command="{Binding DeleteCommand}"
                                Content="Delete" />
                        </StackPanel>
                        <Border Height="5" />
                        <Label
                            Background="#c8102e"
                            Content="Multi-Shots Illumination"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="White" />
                        <Border Height="3" />
                        <DataGrid
                            Name="xShotDataGrid"
                            Width="1105"
                            Height="205"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            ColumnWidth="*"
                            EnableColumnVirtualization="True"
                            EnableRowVirtualization="True"
                            GridLinesVisibility="None"
                            ItemsSource="{Binding DataGridItems}"
                            SelectedIndex="{Binding SelectedIndex}"
                            SelectionMode="Single"
                            SelectionUnit="FullRow"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <DataGrid.Resources>
                                <Style TargetType="{x:Type DataGridRow}">
                                    <Setter Property="BorderBrush" Value="#acacac" />
                                    <Setter Property="Height" Value="26" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="Background" Value="White" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFD2ECFD" />
                                            <Setter Property="Foreground" Value="Black" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>

                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="5" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Grid Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                        </DataGrid>
                    </StackPanel>
                </StackPanel>
                <Border Width="10" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
