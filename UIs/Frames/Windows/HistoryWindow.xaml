<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.HistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ha="http://schemas.mvtec.com/halcondotnet"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    Title="HistoryWindow"
    Width="1100"
    Height="900"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.DataContext>
        <viewModels:HistoryViewModel />
    </Window.DataContext>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="BorderBrush" Value="#acacac" />
            <Setter Property="Height" Value="26" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD2ECFD" />
                    <Setter Property="Foreground" Value="Black" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type DataGridRowHeader}">
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="DataGridTextColumnTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#acacac" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Padding" Value="3,0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFD2ECFD" />
                    <Setter Property="Foreground" Value="Black" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="35" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="#acacac" BorderThickness="1">
        <DockPanel>
            <StackPanel
                Height="30"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <Label Content="History">
                    <Label.Background>
                        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlLightLightColorKey}}" />
                    </Label.Background>
                </Label>
            </StackPanel>

            <StackPanel
                Height="40"
                Margin="5,5,4,4"
                HorizontalAlignment="Right"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Click="exitBtn_Click"
                    Content="Exit" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <Label
                            Width="80"
                            Content="Database"
                            FontSize="15" />
                        <ComboBox
                            Width="180"
                            ItemsSource="{Binding DatabaseNames}"
                            SelectedItem="{Binding SelectedDatabaseName}" />
                        <Border Width="30" />
                        <StackPanel Orientation="Horizontal">
                            <DatePicker Width="130" SelectedDate="{Binding SelectedBeforeDateTime}" />
                            <Label Content="~" FontSize="13" />
                            <DatePicker Width="130" SelectedDate="{Binding SelectedAfterDateTime}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Margin="5" Orientation="Horizontal">
                        <Label
                            Width="50"
                            Content="Filter"
                            FontSize="15" />
                        <ComboBox
                            Width="150"
                            ItemsSource="{Binding RecipeNames}"
                            SelectedItem="{Binding SelectedRecipeName}" />
                        <Border Width="5" />
                        <ComboBox
                            Width="150"
                            ItemsSource="{Binding LotData}"
                            SelectedItem="{Binding SelectedLotData}" />
                        <Border Width="5" />
                        <ComboBox
                            Width="130"
                            ItemsSource="{Binding Cameras}"
                            SelectedItem="{Binding SelectedCamera}" SelectionChanged="ComboBox_SelectionChanged" />
                        <Border Width="5" />
                        <ComboBox
                            Width="130"
                            ItemsSource="{Binding Inspections}"
                            SelectedItem="{Binding SelectedInspection}" />
                        <Border Width="5" />
                        <ComboBox
                            Width="140"
                            ItemsSource="{Binding LogType}"
                            SelectedItem="{Binding SelectedLogType}" />
                        <Border Width="7" />
                        <Button
                            Width="60"
                            Command="{Binding FilterApplyCommand}"
                            Content="Apply" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Margin="3" Orientation="Horizontal">
                    <Border Width="45" />
                    <Button
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding SaveCommand}">
                        <StackPanel Width="50">
                            <Image Margin="4" Source="/Assets/Icons/save.png" />
                            <Label
                                Padding="0,0,0,2"
                                Content="Save"
                                FontSize="9" />
                        </StackPanel>
                    </Button>
                    <Border Width="10" />
                    <Button
                        Command="{Binding deleteSelectedItemsCommand}"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderBrush="Transparent">
                        <StackPanel Width="50">
                            <Image Margin="6" Source="/Assets/Icons/trash.png" />
                            <Label
                                Padding="0,0,0,2"
                                Content="Clear"
                                FontSize="9" />
                        </StackPanel>
                    </Button>
                    <Border Width="10" />
                    <Button
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="ASButton_Click">
                        <StackPanel Width="50">
                            <Image Margin="8" Source="/Assets/Icons/as.png" />
                            <Label
                                Padding="0,0,0,2"
                                Content="A/S"
                                FontSize="9" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="11*" />
                    <ColumnDefinition Width="5*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="18*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="20*" />
                </Grid.RowDefinitions>

                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="1,1,1,0"
                    Padding="2"
                    Background="#c8102e"
                    Content="Histories"
                    FontWeight="Bold"
                    Foreground="White" />
                <Label
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="1,1,1,0"
                    Padding="2"
                    Background="#c8102e"
                    Content="Error Image"
                    FontWeight="Bold"
                    Foreground="White" />
                <DataGrid
                    x:Name="xHistoryDataGrid"
                    Grid.Row="1"
                    Grid.RowSpan="4"
                    Grid.Column="0"
                    Margin="1,0,1,1"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    EnableColumnVirtualization="True"
                    EnableRowVirtualization="True"
                    GridLinesVisibility="None"
                    ItemsSource="{Binding HistoryDataGridItemsSource}"
                    ScrollViewer.ScrollChanged="DataGrid_ScrollChanged"
                    SelectedIndex="{Binding SelectedIndex}"
                    SelectionMode="Extended"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Id}"
                            ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                            Header="NO"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="5*"
                            Binding="{Binding Time}"
                            ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                            Header="TIME"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="3*"
                            Binding="{Binding Package}"
                            ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                            Header="PACKAGE"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="3*"
                            Binding="{Binding LotNumber}"
                            ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                            Header="LOT NUMBER"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="3*"
                            Binding="{Binding Camera}"
                            ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                            Header="CAMERA"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="3*"
                            Binding="{Binding Inspection}"
                            ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                            Header="INSPECTION"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="7*"
                            Binding="{Binding Description}"
                            Header="DESCRIPTION"
                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    <Setter Property="TextWrapping" Value="NoWrap" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectionChanged">
                            <i:InvokeCommandAction Command="{Binding SelectionChangeCommand}" CommandParameter="{Binding ElementName=xHistoryDataGrid, Path=SelectedItems}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </DataGrid>
                <ha:HSmartWindowControlWPF
                    x:Name="xHSmartWindow"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="2,0,2,2" />
                <StackPanel
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button Margin="1" Command="{Binding OpenButtonClickCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Margin="5,5,0,5" Source="/Assets/Icons/folder-open.png" />
                            <Label Padding="5" Content="Open" />
                        </StackPanel>
                    </Button>
                    <Border Width="3" />
                </StackPanel>
                <Label
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="1"
                    Padding="2"
                    Background="#c8102e"
                    Content="Description"
                    FontWeight="Bold"
                    Foreground="White" />
                <TextBox
                    Grid.Row="4"
                    Grid.Column="1"
                    Margin="1,0,1,1"
                    Text="{Binding DescriptionTextBoxText, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </DockPanel>
    </Border>
</Window>
