<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.LightControllerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    Title="LightControllerWindow"
    Width="500"
    Height="300"
    d:DataContext="{d:DesignInstance Type=viewModels:LightViewModel}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>


    <Window.Resources>
        <DataTemplate x:Key="LightControllerItemTemplate">
            <panels:LightControllerPanel x:Name="xLightControllerPanel" DataContext="{Binding}" />
        </DataTemplate>
        <Style TargetType="Button">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>


    <Border BorderBrush="#acacac" BorderThickness="1">
        <DockPanel>
            <StackPanel
                Height="30"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <Label Content="Light Controller">
                    <Label.Background>
                        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlLightLightColorKey}}" />
                    </Label.Background>
                </Label>
            </StackPanel>

            <StackPanel
                Height="40"
                Margin="5,5,4,4"
                HorizontalAlignment="Right"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Command="{Binding SaveCommand}"
                    Content="Save" />
            </StackPanel>

            <StackPanel Width="495">
                <Label
                    Background="#c8102e"
                    Content="Light Control"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="White" />
                <Border Height="5" />
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <Label Content="Camera" />
                    <ComboBox
                        Width="150"
                        Height="30"
                        ItemsSource="{Binding CameraItemsSource}"
                        SelectedValue="{Binding CameraSelectedValue}"
                        SelectionChanged="comboBox_SelectionChanged" />
                </StackPanel>
                <ScrollViewer Height="150">
                    <StackPanel
                        Width="460"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                        <ItemsControl
                            x:Name="xItemsControl"
                            ItemTemplate="{StaticResource LightControllerItemTemplate}"
                            ItemsSource="{Binding LightControllerCollection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
