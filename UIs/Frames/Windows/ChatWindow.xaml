<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.ChatWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    xmlns:li="clr-namespace:LoadingIndicators.WPF;assembly=LoadingIndicators.WPF"
    Title="ChatWindow"
    Width="450"
    Height="580"
    WindowStartupLocation="Manual"
    mc:Ignorable="d">

    <!-- ViewModel을 ChatWindowViewModel로 선정 Window 내부의 모든 UI 요소는 ChatWindowViewModel의 프로퍼티와 바인딩될 수 있다.
    <Window.DataContext>
        <viewModels:ChatWindowViewModel />
    </Window.DataContext>-->

    <DockPanel>
       
        <StackPanel
            Height="40"
            Margin="20"
            HorizontalAlignment="Center"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <Label
                VerticalContentAlignment="Center"
                Content="Model"
                FontSize="20"
                FontWeight="Bold"
                FontFamily="G마켓 산스"
                Foreground="#4A7DFF" />
            <Border Width="16" />
            <ComboBox
                Name="modelComboBox"
                Width="200"
                VerticalContentAlignment="Center"
                Background="White"
                FontSize="17"
                ItemsSource="{Binding ModelList}"
                SelectedItem="{Binding SelectedModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <Button
            Height="32"
            Margin="20,0,20,8"
            Padding="10,2"
            HorizontalAlignment="Left"
            Command="{Binding StartMainWindowGuideCommand}"
            Content="▶ 메인 화면 가이드 시작"
            DockPanel.Dock="Top"
            FontSize="14" />

        <DockPanel
            Margin="20,0,20,8"
            DockPanel.Dock="Top">
            <Button
                x:Name="TrainingButton"
                Width="120"
                Height="30"
                HorizontalAlignment="Left"
                Click="TrainingButton_Click"
                Content="Training">
                <Button.ContextMenu>
                    <ContextMenu Placement="Bottom">
                        <MenuItem
                            Header="Mapping Teaching"
                            Command="{Binding StartMappingTeachingPracticeCommand}" />
                        <MenuItem
                            Header="BGA Teaching"
                            Command="{Binding StartBgaTeachingPracticeCommand}" />
                        <MenuItem
                            Header="Settings Guide"
                            Command="{Binding StartSettingsGuideCommand}" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </DockPanel>

        <DockPanel
            Height="40"
            Margin="10"
            DockPanel.Dock="Bottom">
            <Button
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding SendChatCommand}"
                DockPanel.Dock="Right">

                <Image Width="50" Source="/Assets/Icons/chat/chat_send_button2.png" />
            </Button>
            <Border Width="0" DockPanel.Dock="Right" />
            <TextBox
                x:Name="ChatTextBox"
                AcceptsReturn="True"
                FontSize="17"
                Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="예) bga 티칭 / 시스템 모니터 / 히스토리 / 종료">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SendChatCommand}" />
                </TextBox.InputBindings>
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border
                                        Width="450"
                                        Background="#F3F4F6"
                                        BorderBrush="#F3F4F6"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        SnapsToDevicePixels="True">
                                        <!--  텍스트 입력/출력을 담당하는 영역  -->
                                        <ScrollViewer
                                            x:Name="PART_ContentHost"
                                            Margin="2"
                                            HorizontalScrollBarVisibility="Hidden"
                                            VerticalScrollBarVisibility="Hidden" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </DockPanel>

        <!--  로딩표시(텍스트) 
        <TextBlock
          DockPanel.Dock="Top"
          Text="{Binding TypingStatus}"
          FontStyle="Italic"
          Foreground="Gray"
          HorizontalAlignment="Left"
          Margin="10,0,0,5" /> -->


        <!--  채팅 기록: 위쪽 전체 확장  -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <ListBox
              x:Name="ChatListBox"
              Background="#F9FAFB"
              ItemsSource="{Binding ChatLog}"
              ScrollViewer.VerticalScrollBarVisibility="Auto">
                <!--  좌/우 정렬  -->
                <ListBox.ItemContainerStyle>
                    
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Sender}" Value="User">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Sender}" Value="System">
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <!--  색상 적용  -->
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <Border x:Name="AI_icon" Height="50" Width="50" BorderThickness="1" CornerRadius="100" Background="Bisque" />
                            <StackPanel Margin="6">
                                <Border
                                  x:Name="border"
                                  MaxWidth="180"
                                  MaxHeight="500"
                                  Margin="6"
                                  Padding="9">
                                    <!--  말풍선 내부 내용 세로 배치  -->

                                    <Grid>
                                        <!--  메시지 텍스트  -->
                                        <TextBox
                                        x:Name="textBlock"
                                        Text="{Binding Message}"
                                        FontSize="16"
                                        TextWrapping="Wrap"
                                        AcceptsReturn="True"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        IsReadOnly="True"
                                        IsReadOnlyCaretVisible="True" />


                                        <li:LoadingIndicator
                                            Width="10"
                                            Height="10"
                                            IsActive="{Binding IsLoading}"
                                            Style="{DynamicResource LoadingIndicatorThreeDotsStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,0" />
                                        
                                    </Grid>

                                </Border>


                                <TextBlock
                                    x:Name="timeText"
                                    FontSize="10"
                                    Foreground="#BCBCBC"
                                    Text="{Binding Time}"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                                    
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </StackPanel>
                        </StackPanel>


                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Sender}" Value="User">
                                <Setter TargetName="border" Property="CornerRadius" Value="10,10,0,10" />
                                <Setter TargetName="border" Property="Background" Value="#F0F2F5" />
                                <Setter TargetName="textBlock" Property="Foreground" Value="black" />
                                <Setter TargetName="timeText" Property="Margin" Value="0,0,10,0" />
                                <Setter TargetName="AI_icon" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Sender}" Value="System">
                                <Setter TargetName="border" Property="CornerRadius" Value="10,10,10,0" />
                                <Setter TargetName="border" Property="Background" Value="#4A7DFF" />
                                <Setter TargetName="textBlock" Property="Foreground" Value="White" />
                                <Setter TargetName="timeText" Property="Margin" Value="0,0,170,0" />

                            </DataTrigger>
                            <!--  API 결과 메시지용 스타일  -->
                            <DataTrigger Binding="{Binding Sender}" Value="API">
                                <Setter TargetName="border" Property="Background" Value="#4CAF50" />
                                <Setter TargetName="textBlock" Property="Foreground" Value="White" />
                                <Setter TargetName="textBlock" Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </DockPanel>
</Window>
