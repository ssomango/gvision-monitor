<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.LoadingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LoadingWindow"
    AllowsTransparency="True"
    Background="Transparent"
    KeyDown="window_KeyDown"
    ResizeMode="NoResize"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid
        x:Name="xLoadingWindowGrid"
        Width="600"
        Height="360"
        PreviewMouseDown="xPreviewMouseDown"
        PreviewMouseMove="xPreviewMouseMove">
        <Border
            Background="White"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="25"
                    Opacity="0.5"
                    ShadowDepth="0"
                    Color="Black" />
            </Border.Effect>
            <Canvas Width="600" Height="360">
                <Image
                    Canvas.Left="100"
                    Canvas.Top="33"
                    Width="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    RenderTransformOrigin="0.454,0.499"
                    Source="/Assets/Icons/Logos/deepseers.png" />
                <TextBlock
                    Canvas.Left="222"
                    Canvas.Top="93"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    FontSize="20"
                    FontWeight="Light"
                    Text="Powered by" />
                <mah:ProgressRing
                    Canvas.Left="270"
                    Canvas.Top="206"
                    VerticalAlignment="Top"
                    Foreground="{DynamicResource AccentColorBrush}"
                    IsActive="True"
                    RenderTransformOrigin="4.547, 3.44" />
                <Label
                    x:Name="xMessageLabel"
                    Canvas.Left="50"
                    Canvas.Top="281"
                    Width="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    HorizontalContentAlignment="Center"
                    Content="{Binding Message}"
                    FontSize="16" />
            </Canvas>
        </Border>
    </Grid>
</Window>