<local:FloatingWindowBase
    x:Class="GVisionWpf.UIs.Frames.Windows.CameraWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinWidth="353"
    MinHeight="405"
    d:DesignHeight="300"
    d:DesignWidth="355"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            ResizeBorderThickness="5"
            GlassFrameThickness="5">
        </WindowChrome>
    </WindowChrome.WindowChrome>

    <Border
        Background="DarkGray"
        BorderBrush="#acacac"
        BorderThickness="0"
        CornerRadius="10 10 0 0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="22" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  타이틀바  -->
            <Grid x:Name="xTitleBar" Grid.Row="0">
                <Panels:FloatingWindowTitleBarPanel
                    Title="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                    CanMaximized="{Binding CanMaximized, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                    IsFixed="{Binding IsFixed, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=TwoWay}"
                    IsMaximized="{Binding IsMaximized, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=TwoWay}" />
            </Grid>

            <!--  메인 컨텐츠  -->
            <Border Grid.Row="1">
                <Panels:CameraPanel x:Name="xCameraPanel" />
            </Border>

        </Grid>
    </Border>
</local:FloatingWindowBase>
