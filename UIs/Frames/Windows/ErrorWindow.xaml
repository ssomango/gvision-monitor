<Window
    x:Class="GVisionWpf.UIs.Frames.Windows.ErrorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ErrorWindow"
    Width="750"
    Height="480"
    ResizeMode="NoResize"
    Topmost="True"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Background>
        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
    </Window.Background>
    <Border BorderBrush="#acacac" BorderThickness="0.8">

        <Grid x:Name="xErrorWindowGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="60" />
                <RowDefinition Height="100" />
                <RowDefinition Height="100" />
                <RowDefinition Height="*" />
                <RowDefinition Height="45" />
            </Grid.RowDefinitions>

            <Label
                x:Name="xTitleBarLabel"
                Grid.Row="0"
                VerticalContentAlignment="Center"
                Content="Error Controller">
                <Label.Background>
                    <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlLightLightColorKey}}" />
                </Label.Background>
            </Label>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!--  중국용 경고 할루용 처리 주석 이후 원복 처리  -->
                <!--<Image
                    Grid.Column="0"
                    Width="50"
                    Height="50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Source="/Assets/Icons/x.png" />

                <StackPanel
                    Grid.Column="0"
                    Grid.ColumnSpan="1"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="#d4d5d4"
                    Orientation="Horizontal">
                    <TextBlock
                        x:Name="xErrorName"
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White" />-->

                <StackPanel
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="#d4d5d4"
                    Orientation="Horizontal">
                    <TextBlock
                        x:Name="xErrorName"
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="Black" />
                </StackPanel>
            </Grid>
            <Grid Grid.Row="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Margin="10,5,10,0"
                        FontWeight="Bold"
                        Text="Detail" />

                    <ScrollViewer
                        Grid.Row="1"
                        Margin="10,0,10,0"
                        VerticalScrollBarVisibility="Auto">
                        <TextBox
                            x:Name="xDetailInfo"
                            Width="507"
                            Background="White"
                            Style="{StaticResource LargeTextBoxStyle}"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>
            </Grid>
            <Grid Grid.Row="3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Margin="10,5,10,0"
                        FontWeight="Bold"
                        Text="Trouble Shoot" />

                    <ScrollViewer
                        Grid.Row="1"
                        Margin="10,0,10,0"
                        VerticalScrollBarVisibility="Auto">
                        <TextBox
                            x:Name="xTroubleShootInfo"
                            Width="507"
                            Background="White"
                            Style="{StaticResource LargeTextBoxStyle}"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>
            </Grid>
            <Grid Grid.Row="4">
                <ScrollViewer Margin="10,10,10,0" VerticalScrollBarVisibility="Auto">
                    <TextBox
                        x:Name="xStackTrace"
                        Width="507"
                        Background="White"
                        Style="{StaticResource LargeTextBoxStyle}"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
            <Grid Grid.Row="5">
                <Button
                    x:Name="xFinishButton"
                    Width="80"
                    Height="36"
                    Margin="658,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    BorderBrush="#acacac"
                    Click="closeButton_Click"
                    Content="Finish"
                    FontSize="12">
                    <Button.Background>
                        <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
                    </Button.Background>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
