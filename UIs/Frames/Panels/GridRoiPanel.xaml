<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.GridRoiPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    d:DesignWidth="410"
    DataContext="{Binding}"
    mc:Ignorable="d">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="40"/>
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Label Content="Row" />
            <TextBox
                Width="60"
                Height="26"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Text="{Binding Path=RowSize, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextChanged="onTextChanged" />
            <Border Width="30" />
            <Label Content="Column" />
            <TextBox
                Width="60"
                Height="26"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Text="{Binding Path=ColumnSize, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextChanged="onTextChanged" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,5,0,0">
            <Grid Height="10" Margin="5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Grid.Column="0"
                        Margin="5,0"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        Content="L-TOP"
                        FontSize="9" />
                    <Label
                        Grid.Column="1"
                        Margin="5,0"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        Content="R-BOTTOM"
                        FontSize="9" />
                </Grid>
            </Grid>
            <Grid Height="8" Margin="5,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Grid.Column="0"
                        Margin="5,0"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        Content="ROW (Y)"
                        FontSize="7" />
                    <Label
                        Grid.Column="1"
                        Margin="5,0"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        Content="COL (X)"
                        FontSize="7" />
                    <Label
                        Grid.Column="2"
                        Margin="5,0"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        Content="ROW (Y)"
                        FontSize="7" />
                    <Label
                        Grid.Column="3"
                        Margin="5,0"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        Content="COL (X)"
                        FontSize="7" />
                </Grid>
            </Grid>

        </StackPanel>

        <Label
            x:Name="xRoiLabel"
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,0,5,0"
            HorizontalContentAlignment="Right"
            VerticalContentAlignment="Center"
            Content="{Binding Label, Mode=TwoWay, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type panels:GridRoiPanel}}}" />

        <Grid Grid.Row="2" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40*" />
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="39*" />
                <ColumnDefinition Width="28*"/>
                <ColumnDefinition Width="66*" />
                <ColumnDefinition Width="66*" />
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="xRow1"
                Grid.Column="0"
                Margin="5,0,5,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="#E2E2E2"
                BorderBrush="Transparent"
                FontSize="9"
                Foreground="Gray"
                IsReadOnly="True"
                Text="{Binding Path=Roi.Row1, StringFormat={}{0:F2}, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='null'}"
                TextChanged="onTextChanged" Grid.ColumnSpan="2" />
            <TextBox
                x:Name="xCol1"
                Grid.Column="2"
                Margin="5,0,4,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="#E2E2E2"
                BorderBrush="Transparent"
                FontSize="9"
                Foreground="Gray"
                IsReadOnly="True"
                Text="{Binding Path=Roi.Col1, StringFormat={}{0:F2}, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='null'}"
                TextChanged="onTextChanged" Grid.ColumnSpan="2" />

            <TextBox
                x:Name="xRow2"
                Grid.Column="4"
                Margin="6,0,5,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="#E2E2E2"
                BorderBrush="Transparent"
                FontSize="9"
                Foreground="Gray"
                IsReadOnly="True"
                Text="{Binding Path=Roi.Row2, StringFormat={}{0:F2}, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='null'}"
                TextChanged="onTextChanged" />

            <TextBox
                x:Name="xCol2"
                Grid.Column="5"
                Margin="5,0,5,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="#E2E2E2"
                BorderBrush="Transparent"
                FontSize="9"
                Foreground="Gray"
                IsReadOnly="True"
                Text="{Binding Path=Roi.Col2, StringFormat={}{0:F2}, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='null'}"
                TextChanged="onTextChanged" />
        </Grid>

        <Button
            x:Name="xRoiCreateButton"
            AutomationProperties.AutomationId="GRIDROI_CREATE_BTN"
            Grid.Row="2"
            Grid.Column="2"
            Margin="5,0,0,0"
            VerticalContentAlignment="Center"
            BorderBrush="#acacac"
            Click="roiCreateButton_Click"
            Content="CREATE">
            <Button.Background>
                <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
            </Button.Background>
        </Button>

        <Button 
            AutomationProperties.AutomationId="GRIDROI_DELETE_BTN"
            Grid.Row="2" Grid.Column="3"
            Width="26" Height="26"
            Click="roiDeleteButton_Click">
            <Image Source="/Assets/Icons/undo.png"
             Margin="4"/>
        </Button>
    </Grid>
</UserControl>
