<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.MappingRoiDataListPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ha="http://schemas.mvtec.com/halcondotnet"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:GVisionWpf.Utils"
    d:DesignWidth="440"
    DataContext="{Binding}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="5,0,0,0" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOcrMode, UpdateSourceTrigger=PropertyChanged}" Value="True">
                    <Setter Property="IsReadOnly" Value="true" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOcrMode, UpdateSourceTrigger=PropertyChanged}" Value="False">
                    <Setter Property="IsReadOnly" Value="false" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <StackPanel Height="381" Margin="5,0,5,0">
        <DockPanel>
            <Label Content="{Binding Label, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:MappingRoiDataListPanel}}}" DockPanel.Dock="Left" />
            <Button
                Click="textRoiResetButton_Click"
                Content="RESET"
                DockPanel.Dock="Right" />
            <Button
                Click="textRoiDeleteButton_Click"
                Content="DELETE"
                DockPanel.Dock="Right" />
            <Button
                Click="textRoiAddButton_Click"
                Content="ADD"
                DockPanel.Dock="Right" />
            <Button
                Click="readButton_Click"
                Content="READ"
                DockPanel.Dock="Right" />
            <Border DockPanel.Dock="Right" />
        </DockPanel>

        <Border Height="5" />

        <DataGrid
            x:Name="xTextRoiDataGrid"
            Height="350"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CellEditEnding="onCurrentCellChanged"
            CurrentCellChanged="onCurrentCellChanged"
            EnableColumnVirtualization="True"
            EnableRowVirtualization="True"
            GridLinesVisibility="None"
            ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
            SelectedCellsChanged="textRoiDataGrid_SelectedCellsChanged">
            <DataGrid.Resources>
                <Style TargetType="{x:Type DataGrid}">
                    <Setter Property="Background" Value="WhiteSmoke" />
                    <Setter Property="BorderBrush" Value="#acacac" />
                </Style>
                <Style TargetType="{x:Type DataGridRow}">
                    <Setter Property="BorderBrush" Value="#acacac" />
                    <Setter Property="Height" Value="52" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="Background" Value="WhiteSmoke" />
                </Style>
                <Style TargetType="{x:Type DataGridRowHeader}">
                    <Setter Property="Background" Value="WhiteSmoke" />
                </Style>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="Background" Value="WhiteSmoke" />
                    <Setter Property="Height" Value="26" />
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#acacac" />
                    <Setter Property="BorderThickness" Value="0.5" />
                    <Setter Property="Padding" Value="3,0" />
                    <Setter Property="Background" Value="WhiteSmoke" />
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60" Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Roi.Name, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    Width="*"
                    Header="Row 1"
                    IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox
                                FontSize="9"
                                Foreground="LightGray"
                                Text="{Binding Roi.Row1, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    Width="*"
                    Header="Col 1"
                    IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox
                                FontSize="9"
                                Foreground="LightGray"
                                Text="{Binding Roi.Col1, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    Width="*"
                    Header="Row 2"
                    IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox
                                FontSize="9"
                                Foreground="LightGray"
                                Text="{Binding Roi.Row2, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    Width="*"
                    Header="Col 2"
                    IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox
                                FontSize="9"
                                Foreground="LightGray"
                                Text="{Binding Roi.Col2, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="52" Header="OCR">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="WhiteSmoke"
                                IsChecked="{Binding IsOcrMode, UpdateSourceTrigger=PropertyChanged}">
                                <CheckBox.LayoutTransform>
                                    <ScaleTransform ScaleX="2" ScaleY="2" />
                                </CheckBox.LayoutTransform>
                            </CheckBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="52" Header="Tolerance">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox>
                                <TextBox.Text>
                                    <Binding Path="MinMatchingRate" UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <utils:IntegerRangeRule Max="100" Min="0" />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    Width="100"
                    Header="Result"
                    IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel
                                Height="52"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBox
                                    x:Name="textControl"
                                    VerticalAlignment="Center"
                                    Text="{Binding OcrText, UpdateSourceTrigger=PropertyChanged}"
                                    TextAlignment="Center" />
                                <ha:HSmartWindowControlWPF x:Name="windowControl" />
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsOcrMode, UpdateSourceTrigger=PropertyChanged}" Value="False">
                                    <Setter TargetName="textControl" Property="Width" Value="0" />
                                    <Setter TargetName="windowControl" Property="Width" Value="100" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsOcrMode, UpdateSourceTrigger=PropertyChanged}" Value="True">
                                    <Setter TargetName="textControl" Property="Width" Value="100" />
                                    <Setter TargetName="windowControl" Property="Width" Value="0" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</UserControl>