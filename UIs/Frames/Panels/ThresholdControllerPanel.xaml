<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.ThresholdControllerPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="uc"
    d:DesignHeight="40"
    d:DesignWidth="450"
    DataContext="{Binding}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
    </UserControl.Resources>

    <Grid Height="26" Margin="5">
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                    <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                    <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/light.steel.xaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65" />
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="50" />
        </Grid.ColumnDefinitions>

        <Label
            x:Name="xThresholdControllerLabel"
            Grid.Column="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Right"
            Content="Threshold" />
        <TextBox
            Grid.Column="1"
            Margin="0,0,5,0"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            AcceptsReturn="False"
            BorderBrush="#acacac"
            FontSize="12"
            Text="{Binding Path=Threshold.MinGray, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            TextChanged="textBox_OnTextChanged"
            TextWrapping="Wrap" />
        <mah:RangeSlider
            Grid.Column="2"
            mah:ScrollViewerHelper.IsHorizontalScrollWheelEnabled="True"
            mah:SliderHelper.ChangeValueBy="LargeChange"
            mah:SliderHelper.EnableMouseWheel="MouseHover"
            mah:SliderHelper.TrackValueFillBrush="#FFFF5959"
            mah:SliderHelper.TrackValueFillHoverBrush="#FFFF5959"
            mah:SliderHelper.TrackValueFillPressedBrush="#FFFF2323"
            LargeChange="5"
            LowerValue="{Binding UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Path=Threshold.MinGray, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:ThresholdControllerPanel}}}"
            Maximum="255"
            Minimum="0"
            SmallChange="1"
            UpperValue="{Binding UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Path=Threshold.MaxGray, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:ThresholdControllerPanel}}}" />
        <TextBox
            Grid.Column="3"
            Margin="5,0,0,0"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            AcceptsReturn="False"
            BorderBrush="#acacac"
            FontSize="12"
            Text="{Binding Path=Threshold.MaxGray, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            TextChanged="textBox_OnTextChanged"
            TextWrapping="Wrap" />
        <Button
            Grid.Column="4"
            Margin="10,0"
            Click="Button_OnClick">
            <StackPanel Margin="0">
                <Image Margin="3,0" Source="/Assets/Icons/undo.png" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>