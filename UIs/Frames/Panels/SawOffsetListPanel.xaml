<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.SawOffsetListPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uiModels="clr-namespace:GVisionWpf.Models.UiModels"
    xmlns:utils="clr-namespace:GVisionWpf.Utils"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    x:Name="Root"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="BorderBrush" Value="#acacac" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical">
        <ItemsControl x:Name="xItemsControl"
                      ItemsSource="{Binding ElementName=Root, Path=SawOffsetItems}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <local:SawOffsetPanel x:Name="xSawOffsetPanel"
                                              SawOffsetItem="{Binding}"
                                              SawOffsetStandardObjectSources="{Binding SawOffsetStandardObjects}"
                                              Loaded="xSawOffsetPanel_Loaded"
                                              Unloaded="xSawOffsetPanel_Unloaded"/>
                        <Border Width="10"/>

                        <Button Content="X" Width="20" Background="Transparent" BorderBrush="Transparent" FontSize="20"
                                Click="delete_SawOffsetItem"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Height="10"/>

        <Button Content="+" 
                Width="40" Height="40"
                FontSize="24"
                Padding="0"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                Foreground="Black"
                BorderBrush="#acacac"
                Click="add_SawOffsetItem">

            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <ContentPresenter Margin="0,0,0,10"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"/>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="AliceBlue" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="SkyBlue" />
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</UserControl>