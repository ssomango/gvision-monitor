<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.LightControllerPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="460"
    Height="30"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*" />
            <ColumnDefinition Width="13*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Label
            x:Name="xLightNameLabel"
            Width="140"
            VerticalContentAlignment="Center"
            Content="{Binding LightName}"
            FontSize="13"
            FontWeight="Black" />

        <Slider
            x:Name="xLightSlider"
            Grid.Column="1"
            Width="250"
            Margin="5"
            VerticalAlignment="Center"
            IsSnapToTickEnabled="True"
            Maximum="{Binding Maximum}"
            Value="{Binding Brightness}" />

        <TextBox
            x:Name="xLightTextBox"
            Grid.Column="2"
            Width="50"
            Margin="2"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            AcceptsReturn="False"
            PreviewTextInput="lightTextBox_PreviewTextInput"
            Text="{Binding ElementName=xLightSlider, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            TextWrapping="Wrap" />
    </Grid>
</UserControl>
