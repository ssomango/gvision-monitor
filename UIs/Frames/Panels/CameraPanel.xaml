<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.CameraPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ha="http://schemas.mvtec.com/halcondotnet"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:types="clr-namespace:GVisionWpf.Types"
    xmlns:utils="clr-namespace:GVisionWpf.Utils"
    d:DesignHeight="404"
    d:DesignWidth="376"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
        <utils:EnumToUpperConverter x:Key="EnumToUpperConverter" />
        <utils:CameraPanelToolsToolTipConverter x:Key="ToolBoxTooTipConverter" />
    </UserControl.Resources>

    <Border BorderBrush="#acacac" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    x:Name="xCameraComboBox"
                    Grid.Column="0"
                    VerticalContentAlignment="Center"
                    Background="#f4f4f4"
                    BorderThickness="0,0,1,1"
                    FontWeight="Black"
                    SelectionChanged="comboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToUpperConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button
                    Grid.Column="1"
                    BorderThickness="0,0,1,1"
                    Click="startButton_Click"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:ECameraPanelTools.Start}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image Margin="1" Source="/Assets/Icons/play.png" />
                </Button>

                <Button
                    Grid.Column="2"
                    BorderThickness="0,0,1,1"
                    Click="stopButton_Click"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:ECameraPanelTools.Stop}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image Margin="1" Source="/Assets/Icons/stop.png" />
                </Button>

                <Button
                    Grid.Column="3"
                    BorderThickness="0,0,1,1"
                    Click="saveButton_Click"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:ECameraPanelTools.Save}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image Margin="3" Source="/Assets/Icons/save.png" />
                </Button>

                <Button
                    Grid.Column="4"
                    BorderThickness="0,0,1,1"
                    Click="zoomInButton_Click"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:ECameraPanelTools.ZoomIn}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image Margin="1" Source="/Assets/Icons/zoom-in.png" />
                </Button>

                <Button
                    Grid.Column="5"
                    BorderThickness="0,0,1,1"
                    Click="zoomOutButton_Click"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:ECameraPanelTools.ZoomOut}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image Margin="1" Source="/Assets/Icons/zoom-out.png" />
                </Button>

                <Button
                    Grid.Column="6"
                    BorderThickness="0,0,1,1"
                    Click="zoomResetButton_Click"
                    Style="{StaticResource ImageButtonStyle}"
                    ToolTip="{Binding Source={x:Static types:ECameraPanelTools.ZoomReset}, Converter={StaticResource ToolBoxTooTipConverter}}"
                    ToolTipService.InitialShowDelay="100">
                    <Image Margin="1" Source="/Assets/Icons/reset-zoom.png" />
                </Button>

                <!-- 드롭다운 버튼 -->
                <StackPanel Grid.Column="7">
                    <Button
                        BorderThickness="0,0,0,1"
                        Click="dropdownButton_Click"
                        Style="{StaticResource ImageButtonStyle}"
                        ToolTip="{Binding Source={x:Static types:ECameraPanelTools.Menu}, Converter={StaticResource ToolBoxTooTipConverter}}"
                        ToolTipService.InitialShowDelay="100">
                        <Image Margin="1" Source="/Assets/Icons/menu-dots-vertical.png" />
                    </Button>
                    <!-- 팝업에 리스트 추가 -->
                    <Popup Name="DropdownPopup" PlacementTarget="{Binding ElementName=DropdownButton}" StaysOpen="False" Placement="Bottom">
                        <Border Background="White" BorderBrush="Gray" BorderThickness="1">
                            <ListBox
                                x:Name="xCameraOptions"
                                FontWeight="Black"
                                SelectionChanged="listBox_SelectionChanged"  />
                        </Border>
                    </Popup>
                </StackPanel>

            </Grid>
            <ha:HSmartWindowControlWPF x:Name="xHSmartWindow" Grid.Row="1" />
        </Grid>
    </Border>

</UserControl>