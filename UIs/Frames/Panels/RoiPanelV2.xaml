<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.RoiPanelV2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    d:DesignWidth="410"
    DataContext="{Binding}"
    mc:Ignorable="d">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="40" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="1"
                    Visibility="{Binding HeaderVisibility, RelativeSource={RelativeSource AncestorType={x:Type panels:RoiPanelV2}}}"
                    Margin="0,5,0,0">
            <Grid Height="10" Margin="5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                     Margin="5,0" Padding="0"
                     HorizontalContentAlignment="Center"
                     Content="L-TOP"
                     FontSize="9">
                    </Label>

                    <Label Grid.Column="1"
                     Margin="5,0" Padding="0"
                     HorizontalContentAlignment="Center"
                     Content="R-BOTTOM"
                     FontSize="9">
                    </Label>
                </Grid>
            </Grid>

            <Grid Height="8" Margin="5,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                     Margin="5,0" Padding="0"
                     HorizontalContentAlignment="Center"
                     Content="ROW (Y)"
                     FontSize="7">
                    </Label>

                    <Label Grid.Column="1"
                     Margin="5,0" Padding="0"
                     HorizontalContentAlignment="Center"
                     Content="COL (X)"
                     FontSize="7">
                    </Label>

                    <Label Grid.Column="2"
                     Margin="5,0" Padding="0"
                     HorizontalContentAlignment="Center"
                     Content="ROW (Y)"
                     FontSize="7">
                    </Label>

                    <Label Grid.Column="3"
                     Margin="5,0" Padding="0"
                     HorizontalContentAlignment="Center"
                     Content="COL (X)"
                     FontSize="7">
                    </Label>
                </Grid>
            </Grid>
        </StackPanel>

        <Label Grid.Row="1" Grid.Column="0" x:Name="xRoiLabel"
               Margin="0,0,5,0" Padding="0"
               HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
               Content="{Binding Label, Mode=TwoWay, RelativeSource={RelativeSource AncestorType={x:Type panels:RoiPanelV2}}}">
        </Label>

        <Grid Grid.Row="1" Grid.Column="1" Margin="0, 5, 0, 0">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" x:Name="xRow1"
                     Margin="5,0"
                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                     Background="#E2E2E2" Foreground="Gray" BorderBrush="Transparent"
                     FontSize="9"
                     IsReadOnly="True"
                     Text="{Binding Path=Roi.Row1, StringFormat={}{0:F2}, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='null'}"
                     TextChanged="onTextChanged">
            </TextBox>

            <TextBox Grid.Column="1" x:Name="xCol1"
                     Margin="5,0"
                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                     Background="#E2E2E2" Foreground="Gray" BorderBrush="Transparent"
                     FontSize="9"
                     IsReadOnly="True"
                     Text="{Binding Path=Roi.Col1, StringFormat={}{0:F2}, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='null'}"
                     TextChanged="onTextChanged">
            </TextBox>

            <TextBox Grid.Column="2" x:Name="xRow2"
                     Margin="5,0"
                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                     Background="#E2E2E2" Foreground="Gray" BorderBrush="Transparent"
                     FontSize="9"
                     IsReadOnly="True"
                     Text="{Binding Path=Roi.Row2, StringFormat={}{0:F2}, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='null'}"
                     TextChanged="onTextChanged">
            </TextBox>

            <TextBox Grid.Column="3" x:Name="xCol2"
                     Margin="5,0"
                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                     Background="#E2E2E2" Foreground="Gray" BorderBrush="Transparent"
                     FontSize="9"
                     IsReadOnly="True"
                     Text="{Binding Path=Roi.Col2, StringFormat={}{0:F2}, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='null'}"
                     TextChanged="onTextChanged">
            </TextBox>
        </Grid>

        <Button Grid.Row="1" Grid.Column="2" x:Name="xRoiCreateButton"
                Margin="5,5,0,0"
                VerticalContentAlignment="Center"
                BorderBrush="#acacac"
                Click="roiCreateButton_Click"
                Content="CREATE">
            <Button.Background>
                <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
            </Button.Background>
        </Button>

        <Button Grid.Row="1" Grid.Column="3"
                Width="26" Height="26" Margin="0,5,0,0"
                Click="roiDeleteButton_Click">
            <Image Source="/Assets/Icons/undo.png" Margin="4"/>
        </Button>
    </Grid>
</UserControl>
