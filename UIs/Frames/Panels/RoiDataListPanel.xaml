<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.RoiDataListPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignWidth="440"
    DataContext="{Binding}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="5,0,0,0" />
            <Setter Property="Background" Value="WhiteSmoke" />
            <Setter Property="BorderBrush" Value="#acacac" />
        </Style>
    </UserControl.Resources>

    <StackPanel Height="281" Margin="5">
        <DockPanel>
            <Label
                x:Name="xRoiTextLabel"
                Content="{Binding Label, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:RoiDataListPanel}}}"
                DockPanel.Dock="Left" />
            <Button
                x:Name="xRoiResetButton"
                Click="roiResetButton_Click"
                Content="RESET"
                DockPanel.Dock="Right" />
            <Button
                x:Name="xRoiDeleteButton"
                Click="roiDeleteButton_Click"
                Content="DELETE"
                DockPanel.Dock="Right" />
            <Button
                x:Name="xRoiAddButton"
                Click="roiAddButton_Click"
                Content="ADD"
                DockPanel.Dock="Right" />
            <Border DockPanel.Dock="Right" />
        </DockPanel>

        <Border Height="5" />

        <DataGrid
            x:Name="xRoiDataGrid"
            Height="250"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CellEditEnding="onCellEditEnding"
            EnableColumnVirtualization="True"
            EnableRowVirtualization="True"
            GridLinesVisibility="None"
            ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
            <DataGrid.Resources>
                <Style TargetType="{x:Type DataGrid}">
                    <Setter Property="Background" Value="WhiteSmoke" />
                    <Setter Property="BorderBrush" Value="#acacac" />
                </Style>
                <Style TargetType="{x:Type DataGridRow}">
                    <Setter Property="BorderBrush" Value="#acacac" />
                    <Setter Property="Height" Value="26" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="Background" Value="WhiteSmoke" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FFD2ECFD" />
                            <Setter Property="Foreground" Value="Black" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
                <Style TargetType="{x:Type DataGridRowHeader}">
                    <Setter Property="Background" Value="WhiteSmoke" />
                </Style>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="Background" Value="WhiteSmoke" />
                    <Setter Property="Height" Value="30" />
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
                <Style x:Key="DataGridTextColumnTextStyle" TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="HorizontalAlignment" Value="Center" />
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#acacac" />
                    <Setter Property="BorderThickness" Value="0.5" />
                    <Setter Property="Padding" Value="3,0" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FFD2ECFD" />
                            <Setter Property="Foreground" Value="Black" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn
                    x:Name="xRoiName"
                    Width="*"
                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
                    ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                    Header=""
                    IsReadOnly="True" />
                <DataGridTextColumn
                    x:Name="xRoiRow1"
                    Width="*"
                    Binding="{Binding Row1, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
                    ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                    Foreground="LightGray"
                    Header="Row 1"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    x:Name="xRoiCol1"
                    Width="*"
                    Binding="{Binding Col1, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
                    ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                    Foreground="LightGray"
                    Header="Col 1"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    x:Name="xRoiRow2"
                    Width="*"
                    Binding="{Binding Row2, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
                    ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                    Foreground="LightGray"
                    Header="Row 2"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    x:Name="xRoiCol2"
                    Width="*"
                    Binding="{Binding Col2, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
                    ElementStyle="{StaticResource DataGridTextColumnTextStyle}"
                    Foreground="LightGray"
                    Header="Col 2"
                    IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</UserControl>