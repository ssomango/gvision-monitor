<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.TeachingToolsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:types="clr-namespace:GVisionWpf.Types"
    xmlns:utils="clr-namespace:GVisionWpf.Utils"
    d:DesignHeight="45"
    d:DesignWidth="380"
    mc:Ignorable="d">

    <UserControl.Resources>
        <utils:VisionWindowToolsToolTipConverter x:Key="ToolBoxTooTipConverter" />
    </UserControl.Resources>

    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
        <Button
            Click="zoomInMenuItem_Click"
            Style="{StaticResource ImageButtonStyle}"
            ToolTip="{Binding Source={x:Static types:EVisionWindowTools.ZoomIn}, Converter={StaticResource ToolBoxTooTipConverter}}"
            ToolTipService.InitialShowDelay="100">
            <Image Margin="2" Source="/Assets/Icons/zoom-in.png" />
        </Button>
        <Border Width="10" />
        <Button
            Click="zoomOutMenuItem_Click"
            Style="{StaticResource ImageButtonStyle}"
            ToolTip="{Binding Source={x:Static types:EVisionWindowTools.ZoomOut}, Converter={StaticResource ToolBoxTooTipConverter}}"
            ToolTipService.InitialShowDelay="100">
            <Image Margin="2" Source="/Assets/Icons/zoom-out.png" />
        </Button>
        <Border Width="10" />
        <Button
            Click="resetZoomMenuItem_Click"
            Style="{StaticResource ImageButtonStyle}"
            ToolTip="{Binding Source={x:Static types:EVisionWindowTools.ZoomReset}, Converter={StaticResource ToolBoxTooTipConverter}}"
            ToolTipService.InitialShowDelay="100">
            <Image Margin="2" Source="/Assets/Icons/reset-zoom.png" />
        </Button>
        <Border Width="10" />
        <Button
            Click="grayValueButton_Click"
            Style="{StaticResource ImageButtonStyle}"
            ToolTip="{Binding Source={x:Static types:EVisionWindowTools.GrayValue}, Converter={StaticResource ToolBoxTooTipConverter}}"
            ToolTipService.InitialShowDelay="100">
            <Image Margin="2" Source="/Assets/Icons/grayValue.png" />
        </Button>
        <Border Width="10" />
        <Button
            Click="rulerButton_Click"
            Style="{StaticResource ImageButtonStyle}"
            ToolTip="{Binding Source={x:Static types:EVisionWindowTools.Ruler}, Converter={StaticResource ToolBoxTooTipConverter}}"
            ToolTipService.InitialShowDelay="100">
            <Image Margin="4" Source="/Assets/Icons/ruler.png" />
        </Button>
        <Border Width="10" />
        <Button
            Click="lineProfileButton_Click"
            Style="{StaticResource ImageButtonStyle}"
            ToolTip="{Binding Source={x:Static types:EVisionWindowTools.LineProfile}, Converter={StaticResource ToolBoxTooTipConverter}}"
            ToolTipService.InitialShowDelay="100">
            <Image Margin="4" Source="/Assets/Icons/line-profile.png" />
        </Button>
        <Border Width="10" />
        <Button
            Click="saveImageButton_Click"
            Style="{StaticResource ImageButtonStyle}"
            ToolTip="{Binding Source={x:Static types:EVisionWindowTools.SaveImage}, Converter={StaticResource ToolBoxTooTipConverter}}"
            ToolTipService.InitialShowDelay="100">
            <Image Margin="4" Source="/Assets/Icons/save.png" />
        </Button>
    </StackPanel>
</UserControl>
