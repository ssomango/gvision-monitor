<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.TrackerMovingPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="214"
    d:DesignWidth="380"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <!--  왼쪽 칸  -->
            <ColumnDefinition Width="*" />
            <!--  오른쪽 칸  -->
        </Grid.ColumnDefinitions>

        <!--  Tracker Moving 체크박스  -->
        <CheckBox
            x:Name="xRoiAdjustToRoiMoveToggleCheckBox"
            Grid.ColumnSpan="2"
            Margin="16,0,0,0"
            BorderBrush="#acacac"
            Checked="disableMinusButton_Checked"
            Content="Tracker Moving"
            IsChecked="False"
            Unchecked="enableMinusButton_Unchecked" />

        <!--  왼쪽 그리드  -->
        <Grid
            x:Name="xPlusButtonGrid"
            Grid.Row="1"
            Grid.Column="0"
            Margin="15,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  3x3 버튼 배치  -->
            <!--  1행  -->
            <Button
                x:Name="xTopLeftPlusButton"
                Grid.Column="0"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Assets/Icons/Tracker/arrow-up-left.png" />
                </Button.Content>
            </Button>

            <Button
                x:Name="xTopPlusButton"
                Grid.Row="0"
                Grid.Column="1"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="30"
                        Height="30"
                        Source="/Assets/Icons/Tracker/arrow-up.png" />
                </Button.Content>
            </Button>
            <Button
                x:Name="xTopRightPlusButton"
                Grid.Row="0"
                Grid.Column="2"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Assets/Icons/Tracker/arrow-up-right.png" />
                </Button.Content>
            </Button>

            <!--  2행  -->
            <Button
                x:Name="xLeftPlusButton"
                Grid.Row="1"
                Grid.Column="0"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="30"
                        Height="30"
                        Source="/Assets/Icons/Tracker/arrow-left.png" />
                </Button.Content>
            </Button>
            <Button
                x:Name="xRightPlusButton"
                Grid.Row="1"
                Grid.Column="2"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="30"
                        Height="30"
                        Source="/Assets/Icons/Tracker/arrow-right.png" />
                </Button.Content>
            </Button>

            <!--  3행  -->
            <Button
                x:Name="xBottomLeftPlusButton"
                Grid.Row="2"
                Grid.Column="0"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Assets/Icons/Tracker/arrow-down-left.png" />
                </Button.Content>
            </Button>
            <Button
                x:Name="xBottomPlusButton"
                Grid.Row="2"
                Grid.Column="1"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="30"
                        Height="30"
                        Source="/Assets/Icons/Tracker/arrow-down.png" />
                </Button.Content>
            </Button>
            <Button
                x:Name="xBottomRightPlusButton"
                Grid.Row="2"
                Grid.Column="2"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Assets/Icons/Tracker/arrow-down-right.png" />
                </Button.Content>
            </Button>
        </Grid>

        <!--  오른쪽 그리드  -->
        <Grid
            x:Name="xMinusButtonGrid"
            Grid.Row="1"
            Grid.Column="1"
            Margin="15,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  1행  -->
            <Button
                x:Name="xTopLeftMinusButton"
                Grid.Row="0"
                Grid.Column="0"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Assets/Icons/Tracker/arrow-down-right.png" />
                </Button.Content>
            </Button>

            <Button
                x:Name="xTopMinusButton"
                Grid.Row="0"
                Grid.Column="1"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="30"
                        Height="30"
                        Source="/Assets/Icons/Tracker/arrow-down.png" />
                </Button.Content>
            </Button>
            <Button
                x:Name="xTopRightMinusButton"
                Grid.Row="0"
                Grid.Column="2"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Assets/Icons/Tracker/arrow-down-left.png" />
                </Button.Content>
            </Button>

            <!--  2행  -->
            <Button
                x:Name="xLeftMinusButton"
                Grid.Row="1"
                Grid.Column="0"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="30"
                        Height="30"
                        Source="/Assets/Icons/Tracker/arrow-right.png" />
                </Button.Content>
            </Button>
            <Button
                x:Name="xRightMinusButton"
                Grid.Row="1"
                Grid.Column="2"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="30"
                        Height="30"
                        Source="/Assets/Icons/Tracker/arrow-left.png" />
                </Button.Content>
            </Button>

            <!--  3행  -->
            <Button
                x:Name="xBottomLeftMinusButton"
                Grid.Row="2"
                Grid.Column="0"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Assets/Icons/Tracker/arrow-up-right.png" />
                </Button.Content>
            </Button>
            <Button
                x:Name="xBottomMinusButton"
                Grid.Row="2"
                Grid.Column="1"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="30"
                        Height="30"
                        Source="/Assets/Icons/Tracker/arrow-up.png" />
                </Button.Content>
            </Button>
            <Button
                x:Name="xBottomRightMinusButton"
                Grid.Row="2"
                Grid.Column="2"
                Margin="2"
                Background="White">
                <Button.Content>
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Assets/Icons/Tracker/arrow-up-left.png" />
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</UserControl>
