<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.InspectionResultPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="30"
    d:DesignWidth="376"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ScaleTransform x:Key="LargeScale" ScaleX="1.4" ScaleY="1.4" />
        <Style x:Key="LargeCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="LayoutTransform" Value="{StaticResource LargeScale}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsChecked" Value="True" />
        </Style>
        <Style x:Key="LargeTextBoxStyle" TargetType="TextBox">
            <Setter Property="LayoutTransform" Value="{StaticResource LargeScale}" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Margin" Value="2" />
        </Style>
        <Style x:Key="LargeTextBlockStyle" TargetType="TextBlock">
            <Setter Property="LayoutTransform" Value="{StaticResource LargeScale}" />
            <Setter Property="Margin" Value="2" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="xInspectionResultGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="11*" />
            <ColumnDefinition Width="10*" />
            <ColumnDefinition Width="5*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CheckBox
            x:Name="xInspectionResultCheckBox"
            Grid.Row="0"
            Grid.Column="0"
            Content="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Style="{StaticResource LargeCheckBoxStyle}" />

        <TextBox
            x:Name="xInspectionResultTextBox"
            Grid.Row="0"
            Grid.Column="1"
            Style="{StaticResource LargeTextBoxStyle}"
            Text="{Binding Result, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBox
            x:Name="xInspectionResultCountTextBox"
            Grid.Row="0"
            Grid.Column="2"
            Style="{StaticResource LargeTextBoxStyle}"
            Text="{Binding ResultCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </Grid>
</UserControl>
