<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.LotInfoPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:GVisionWpf.Utils"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:CurrentSettingViewmodel}"
    d:DesignHeight="35"
    d:DesignWidth="750"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="Label">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Black" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <utils:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label
            Grid.Column="0"
            Background="Black"
            Content="Recipe"
            Foreground="White" />

        <Label
            Grid.Column="1"
            Background="White"
            Content="{Binding RecipeName}"
            Foreground="{Binding RecipeNameColor, Converter={StaticResource ColorToBrushConverter}}" />

        <Label
            Grid.Column="2"
            Background="Black"
            Content="LOT Number"
            Foreground="White" />

        <Border Grid.Column="3" Background="White">
            <Label Content="{Binding LotNumber}" Foreground="{Binding LotNumberColor, Converter={StaticResource ColorToBrushConverter}}" />
        </Border>
    </Grid>
</UserControl>
