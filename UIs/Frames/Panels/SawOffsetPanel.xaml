<UserControl
    x:Class="GVisionWpf.UIs.Frames.Panels.SawOffsetPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:type="clr-namespace:GVisionWpf.Types"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uiModels="clr-namespace:GVisionWpf.Models.UiModels"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    x:Name="Root"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="BorderBrush" Value="#acacac" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <local:PointPickPanel
                x:Name="xPointPickPanel"
                Width="329"
                Label="Standard Object"
                Point="{Binding ElementName=Root, Path=SawOffsetItem.SawOffsetTargetPoint}"
                Color="green"/>
            <Border Width="5"/>

            <ComboBox
                x:Name="xStandardObjectComboBox"
                Width="80"
                Height="26"
                ItemsSource="{Binding ElementName=Root, Path=SawOffsetStandardObjectSources}"
                SelectedValue="{Binding ElementName=Root, Path=SawOffsetItem.SelectedSawOffsetStandardObject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        
        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
            <Label Content="TOP"/>
            <CheckBox x:Name="xCheckBox_Top"
                Checked="checkBox_Checked"
                Unchecked="checkBox_Unchecked"
                CommandParameter="{x:Static type:EDirection.Top}"/>
            <Border Width="10"/>
            
            <Label Content="BOTTOM"/>
            <CheckBox x:Name="xCheckBox_Bottom"
                Checked="checkBox_Checked"
                Unchecked="checkBox_Unchecked"
                CommandParameter="{x:Static type:EDirection.Bottom}"/>
            <Border Width="10"/>
            
            <Label Content="LEFT"/>
            <CheckBox x:Name="xCheckBox_Left"
                Checked="checkBox_Checked"
                Unchecked="checkBox_Unchecked"
                CommandParameter="{x:Static type:EDirection.Left}"/>
            <Border Width="10"/>
            
            <Label Content="RIGHT"/>
            <CheckBox x:Name="xCheckBox_Right"
                Checked="checkBox_Checked"
                Unchecked="checkBox_Unchecked"
                CommandParameter="{x:Static type:EDirection.Right}"/>
        </StackPanel>
    </StackPanel>
</UserControl>