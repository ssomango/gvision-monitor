      {
        "datasource": {
          "uid": "gvision_sqlite"
        },
        "enable": true,
        "hide": false,
        "iconColor": "blue",
        "name": "LOT 이벤트",
        "rawQuery": "SELECT strftime('%Y-%m-%dT%H:%M:%SZ', datetime(substr(Time,1,19), '-9 hours')) AS time, substr(Description,1,60) AS text, 'LOT' AS tags FROM histories WHERE LogType = 4 AND Time >= datetime('now', '-15 hours') ORDER BY Time ASC",
        "timeColumns": [
          "time"
        ]
      },
      {
        "datasource": {
          "uid": "gvision_sqlite"
        },
        "enable": true,
        "hide": false,
        "iconColor": "purple",
        "name": "Recipe 변경",
        "rawQuery": "SELECT strftime('%Y-%m-%dT%H:%M:%SZ', datetime(substr(Time,1,19), '-9 hours')) AS time, substr(Description,1,60) AS text, 'Recipe' AS tags FROM histories WHERE LogType = 5 AND Time >= datetime('now', '-15 hours') ORDER BY Time ASC",
        "timeColumns": [
          "time"
        ]
      },
      {
        "datasource": {
          "uid": "gvision_sqlite"
        },
        "enable": true,
        "hide": false,
        "iconColor": "red",
        "name": "시스템 이벤트",
        "rawQuery": "SELECT strftime('%Y-%m-%dT%H:%M:%SZ', datetime(substr(Time,1,19), '-9 hours')) AS time, trim(substr(Description,1,60)) AS text, 'System' AS tags FROM histories WHERE LogType = 1 AND Time >= datetime('now', '-15 hours') ORDER BY Time ASC",
        "timeColumns": [
          "time"
        ]
      },
      {
        "datasource": {
          "uid": "gvision_sqlite"
        },
        "enable": true,
        "hide": false,
        "iconColor": "orange",
        "name": "Teaching 변경",
        "rawQuery": "SELECT strftime('%Y-%m-%dT%H:%M:%SZ', datetime(substr(Time,1,19), '-9 hours')) AS time, CASE WHEN instr(Description,char(10))>0 THEN trim(substr(Description,1,instr(Description,char(10))-1)) ELSE trim(substr(Description,1,60)) END AS text, 'Teaching' AS tags FROM histories WHERE LogType = 5 AND Description LIKE '%Teaching%' AND Time >= datetime('now', '-15 hours') ORDER BY Time ASC",
        "timeColumns": [
          "time"
        ]
      },
      {
        "datasource": {
          "uid": "gvision_sqlite"
        },
        "enable": true,
        "hide": false,
        "iconColor": "dark-red",
        "name": "시스템 예외 발생",
        "rawQuery": "SELECT strftime('%Y-%m-%dT%H:%M:%SZ', datetime(substr(Time,1,19), '-9 hours')) AS time, CASE WHEN Description LIKE '%CameraTimeout%' OR Description LIKE '%NotInitializedCamera%' OR Description LIKE '%PrsImageDequeue%' THEN '[카메라] ' WHEN Description LIKE '%Udp%' THEN '[통신] ' WHEN Description LIKE '%Vision%' THEN '[비전] ' WHEN Description LIKE '%NoIllumination%' OR Description LIKE '%UnknownLight%' THEN '[조명] ' WHEN Description LIKE '%WrongSetting%' OR Description LIKE '%WrongGrid%' THEN '[설정] ' ELSE '[시스템] ' END || substr(Description, instr(Description, '] ')+2, 50) AS text, 'exception' AS tags FROM histories WHERE LogType=1 AND Description LIKE '%Exception:%' AND Time >= datetime('now', '-15 hours') ORDER BY Time ASC",
        "timeColumns": [
          "time"
        ]
      }
    ]
  },
