{
  "title": "01. 장비 실시간 상태",
  "uid": "gvision-status",
  "tags": ["gvision", "status"],
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "장비 모드",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": { "uid": "gvision_api" },
      "options": {
        "colorMode": "background",
        "textMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [ "lastNotNull" ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OFFLINE",
                  "color": "gray"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "RUN",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "SETUP",
                  "color": "yellow"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "gray"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_api" },
          "refId": "A",
          "queryType": "infinity",
          "type": "csv",
          "source": "url",
          "format": "table",
          "url": "http://localhost:4000/api/status/mode",
          "url_options": { "method": "GET" },
          "columns": [
            {
              "selector": "value",
              "text": "모드",
              "type": "number"
            }
          ],
          "filters": []
        }
      ]
    },
    {
      "id": 2,
      "title": "현재 Recipe",
      "type": "table",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": { "uid": "gvision_status_db" },
      "options": {
        "cellHeight": "lg",
        "footer": { "show": false },
        "showHeader": false
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          },
          "custom": {
            "align": "center",
            "cellOptions": {
              "type": "colored-background",
              "fillOpacity": 80
            },
            "filterable": false
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_status_db" },
          "refId": "A",
          "rawQueryText": "SELECT value AS Recipe FROM current_status WHERE key = 'recipeName' LIMIT 1",
          "timeColumns": []
        }
      ]
    },
    {
      "id": 3,
      "title": "현재 Lot 번호",
      "type": "table",
      "gridPos": {
        "x": 10,
        "y": 0,
        "w": 7,
        "h": 4
      },
      "datasource": { "uid": "gvision_status_db" },
      "options": {
        "cellHeight": "lg",
        "footer": { "show": false },
        "showHeader": false
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          },
          "custom": {
            "align": "center",
            "cellOptions": {
              "type": "colored-background",
              "fillOpacity": 80
            },
            "filterable": false
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_status_db" },
          "refId": "A",
          "rawQueryText": "SELECT value AS LotNo FROM current_status WHERE key = 'lotNo' LIMIT 1",
          "timeColumns": []
        }
      ]
    },
    {
      "id": 4,
      "title": "모바일 연결 수",
      "type": "stat",
      "gridPos": {
        "x": 17,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": { "uid": "gvision_api" },
      "options": {
        "colorMode": "value",
        "textMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [ "lastNotNull" ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "gray"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_api" },
          "refId": "A",
          "queryType": "infinity",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://localhost:4000/api/status",
          "url_options": { "method": "GET" },
          "root_selector": "rows",
          "columns": [
            {
              "selector": "connectedClients",
              "text": "연결수",
              "type": "number"
            }
          ],
          "filters": []
        }
      ]
    },
    {
      "id": 5,
      "title": "최근 이벤트 로그",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 12
      },
      "datasource": { "uid": "gvision_sqlite" },
      "options": {
        "sortBy": [
          {
            "displayName": "시각",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "구분"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "시스템": {
                        "text": "시스템",
                        "color": "red"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "LOT": {
                        "text": "LOT",
                        "color": "blue"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "Recipe": {
                        "text": "Recipe",
                        "color": "purple"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "Teaching": {
                        "text": "Teaching",
                        "color": "orange"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "시각"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_sqlite" },
          "refId": "A",
          "rawQueryText": "SELECT strftime('%Y-%m-%d %H:%M:%S', datetime(substr(Time,1,19), '-9 hours')) AS 시각, CASE LogType WHEN 1 THEN '시스템' WHEN 5 THEN CASE WHEN Description LIKE '%Teaching%' THEN 'Teaching' ELSE 'Recipe' END WHEN 4 THEN 'LOT' ELSE CAST(LogType AS TEXT) END AS 구분, CASE WHEN instr(Description, char(10)) > 0 THEN trim(substr(Description,1,instr(Description,char(10))-1)) ELSE trim(substr(Description,1,100)) END AS 내용 FROM histories WHERE (LogType=1 OR LogType=5 OR (LogType=4 AND Description NOT LIKE '%INSPECTION RESULT%')) ORDER BY Time DESC LIMIT 50",
          "timeColumns": []
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "오늘 요약",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },

    {
      "id": 6,
      "title": "현재 수율 (최근 5분)",
      "type": "gauge",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 4,
        "h": 5
      },
      "datasource": { "uid": "gvision_sqlite" },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 90,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 98,
                "color": "yellow"
              },
              {
                "value": 99,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_sqlite" },
          "refId": "A",
          "rawQueryText": "SELECT ROUND(SUM(CASE WHEN Item='PASS' THEN 1.0 ELSE 0 END)/COUNT(*)*100,2) AS value FROM inspection_results WHERE StartTIme >= date('now', '+9 hours')",
          "timeColumns": []
        }
      ]
    },

    {
      "id": 7,
      "title": "총 검사 건수 (오늘)",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 27,
        "w": 4,
        "h": 5
      },
      "datasource": { "uid": "gvision_sqlite" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": [ "lastNotNull" ] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_sqlite" },
          "refId": "A",
          "rawQueryText": "SELECT COUNT(*) AS value FROM inspection_results WHERE date(StartTIme) = date('now', '+9 hours')",
          "timeColumns": []
        }
      ]
    },

    {
      "id": 8,
      "title": "불량 건수 (오늘)",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 27,
        "w": 4,
        "h": 5
      },
      "datasource": { "uid": "gvision_sqlite" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": [ "lastNotNull" ] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 50,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_sqlite" },
          "refId": "A",
          "rawQueryText": "SELECT COUNT(*) AS value FROM inspection_results WHERE Item != 'PASS' AND date(StartTIme) = date('now', '+9 hours')",
          "timeColumns": []
        }
      ]
    },

    {
      "id": 9,
      "title": "이벤트 발생 수 (오늘)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 4,
        "h": 5
      },
      "datasource": { "uid": "gvision_sqlite" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": [ "lastNotNull" ] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_sqlite" },
          "refId": "A",
          "rawQueryText": "SELECT COUNT(*) AS value FROM histories WHERE date(Time) = date('now', '+9 hours')",
          "timeColumns": []
        }
      ]
    },

    {
      "id": 10,
      "title": "평균 처리시간 (오늘)",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 27,
        "w": 4,
        "h": 5
      },
      "datasource": { "uid": "gvision_sqlite" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": [ "lastNotNull" ] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 150,
                "color": "yellow"
              },
              {
                "value": 200,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "gvision_sqlite" },
          "refId": "A",
          "rawQueryText": "SELECT ROUND(AVG(Duration),1) AS value FROM inspection_results WHERE date(StartTIme) = date('now', '+9 hours')",
          "timeColumns": []
        }
      ]
    }
  ],

  "schemaVersion": 39
}
