      "targets": [
        {
          "datasource": {
            "uid": "gvision_sqlite"
          },
          "rawQueryText": "SELECT strftime('%Y-%m-%dT%H:%M:00Z', datetime(StartTIme, '-9 hours')) AS time, ROUND(SUM(CASE WHEN Item = 'PASS' THEN 1.0 ELSE 0 END) / COUNT(*) * 100, 2) AS yield FROM inspection_results WHERE StartTIme >= datetime('now', '-15 hours') GROUP BY strftime('%Y-%m-%dT%H:%M:00', datetime(StartTIme, '-9 hours')) ORDER BY time ASC",
          "refId": "A",
          "timeColumns": [
            "time"
          ]
        },
        {
          "datasource": {
            "uid": "gvision_sqlite"
          },
          "rawQueryText": "SELECT strftime('%Y-%m-%dT%H:%M:00Z', datetime(StartTIme, '-9 hours')) AS time, 99.0 AS target FROM inspection_results WHERE StartTIme >= datetime('now', '-15 hours') GROUP BY strftime('%Y-%m-%dT%H:%M:00', datetime(StartTIme, '-9 hours')) ORDER BY time ASC",
          "refId": "B",
          "timeColumns": [
            "time"
          ]
        }
      ],
      "title": "수율 (Yield) 추이 — SPC 관리도",
      "type": "timeseries"
    },
