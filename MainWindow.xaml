<Window
    x:Class="GVisionWpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ha="http://schemas.mvtec.com/halcondotnet"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:GVisionWpf.UIs.Frames.Panels"
    xmlns:viewModels="clr-namespace:GVisionWpf.UIs.ViewModels"
    xmlns:li="http://github.com/zeluisping/loadingIndicators/xaml/controls"
    Title="MainWindow"
    Width="1280"
    Height="1024"
    StateChanged="Window_StateChanged"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.DataContext>
        <viewModels:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="NoHoverButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True" />
                <Trigger Property="IsPressed" Value="True" />
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="xMainWindowBorder" Margin="0" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="100" />
                <RowDefinition Height="70" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
                <RowDefinition Height="90" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Margin="5,0" Content="{Binding TitleName}" />

            <!-- 타이틀바 -->
            <Border
                Grid.Row="0"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                PreviewMouseDown="titleBarLabel_PreviewMouseDown"
                PreviewMouseMove="titleBarLabel_PreviewMouseMove">
                <panels:ModeInfoPanel x:Name="xModeInfoPanel" />
            </Border>

            <!-- 로고 -->
            <Button
                x:Name="xLogoButton"
                Grid.Row="1"
                Grid.Column="0"
                Height="100"
                Margin="10,0"
                Click="logoImage_OnClick"
                Style="{StaticResource NoHoverButtonStyle}">
                <Image Source="{Binding LogoImagePath}" />
            </Button>

            <!-- Operation 버튼 -->
            <Button
                x:Name="xOperationButton"
                Grid.Row="2"
                Grid.Column="0"
                BorderThickness="0"
                Click="operationButton_OnClick"
                Content="SETUP"
                Cursor="Hand"
                FontSize="23"
                FontWeight="UltraBold"
                Foreground="#D10000">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </Button.Resources>
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid x:Name="xOperationButtonGrid" Background="White">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*" />
                                <ColumnDefinition Width="9*" />
                            </Grid.ColumnDefinitions>
                            <Image
                                x:Name="xOperationButtonImage"
                                Grid.Column="0"
                                Margin="15,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Source="/Assets/Icons/Run.png" />
                            <ContentPresenter
                                Grid.Column="1"
                                Margin="5,0,0,2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- 좌측 사이드바 -->
            <ScrollViewer
                x:Name="xSidebarScrollViewer"
                Grid.Row="3"
                Grid.RowSpan="3"
                Grid.Column="0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Hidden">
                <StackPanel>
                    <ItemsControl
                        x:Name="xSidebarItemsControl"
                        AutomationProperties.AutomationId="MAIN_SIDEBAR_ITEMS"
                        ItemsSource="{Binding SidebarTabs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander FontSize="15" Header="{Binding TabName}" IsExpanded="{Binding IsExpanded}">
                                    <Expander.Style>
                                        <Style TargetType="Expander">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Expander">
                                                        <StackPanel>
                                                            <ToggleButton
                                                                x:Name="HeaderSite"
                                                                Height="30"
                                                                HorizontalContentAlignment="Center"
                                                                VerticalContentAlignment="Center"
                                                                AutomationProperties.AutomationId="{Binding TabName}"
                                                                AutomationProperties.Name="{Binding TabName}"
                                                                Background="WhiteSmoke"
                                                                BorderBrush="Black"
                                                                BorderThickness="1"
                                                                Content="{TemplateBinding Header}"
                                                                FontWeight="Bold"
                                                                IsChecked="{Binding Path=IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border
                                                                            Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="5">
                                                                            <ContentPresenter
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                Content="{TemplateBinding Content}" />
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" />
                                                        </StackPanel>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsExpanded" Value="True">
                                                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Expander.Style>

                                    <ItemsControl ItemsSource="{Binding Buttons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button
                                                        Width="140"
                                                        Height="50"
                                                        Margin="5"
                                                        Background="White"
                                                        BorderThickness="0"
                                                        Command="{Binding Command}"
                                                        AutomationProperties.AutomationId="{Binding Name}"
                                                        AutomationProperties.Name="{Binding Name}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Image Width="40" Source="{Binding IconPath}" />
                                                            <Border Width="5" />
                                                            <Label
                                                                Width="100"
                                                                VerticalContentAlignment="Center"
                                                                Content="{Binding Name}"
                                                                FontSize="14" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>



            <!-- 좌측 하단 버튼 -->
            <Button
                x:Name="xConnectionBtn"
                Grid.Row="6"
                Grid.Column="0"
                Height="40"
                VerticalAlignment="Bottom"
                Background="Red"
                BorderThickness="0"
                Click="connectionBtn_OnClick"
                Content="DISCONNECTED"
                Cursor="Hand"
                DockPanel.Dock="Bottom"
                FontSize="18"
                FontWeight="UltraBold"
                Foreground="White" />


            <!-- 현재 로트 정보 -->
            <Border
                x:Name="xBottomArea"
                Grid.Row="4"
                Grid.RowSpan="3"
                Grid.Column="1"
                Background="Transparent"
                IsHitTestVisible="False"
                AutomationProperties.AutomationId="MAIN_BOTTOM_AREA" />

            <panels:LotInfoPanel
                x:Name="xLotInfoPanel"
                Grid.Row="4"
                Grid.Column="1" />

            <!-- 검사 통계 -->
            <panels:StatisticsPanel
                x:Name="xStatisticsPanel"
                Grid.Row="5"
                Grid.RowSpan="2"
                Grid.Column="1" />

            <!-- 시스템 정보 패널 (기준 위치) -->
            <panels:SystemInformationPanel
                x:Name="systemInformationPanel"
                Grid.Row="4"
                Grid.RowSpan="3"
                Grid.Column="2" />

            <!-- 메인 프레임 -->
            <Frame
                x:Name="xMainFrame"
                AutomationProperties.AutomationId="MAIN_MAINFRAME"
                Grid.Row="1"
                Grid.RowSpan="3"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                BorderBrush="#acacac"
                BorderThickness="0,1,0,0"
                NavigationUIVisibility="Hidden">
                <Frame.Background>
                    <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
                </Frame.Background>
            </Frame>
        </Grid>
    </Border>
</Window>
